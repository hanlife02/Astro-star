{
  "name": "Astro-star",
  "type": "module",
  "version": "0.16.5",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "predev": "node --experimental-strip-types scripts/generate-git-timestamps.ts",
    "dev": "astro dev",
    "prebuild": "node --experimental-strip-types scripts/generate-git-timestamps.ts",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "astro": "astro",
    "algolia:sync": "node --experimental-strip-types scripts/sync-algolia-index.ts",
    "audit:assets": "node --experimental-strip-types scripts/audit-assets.ts",
    "audit:content": "node --experimental-strip-types scripts/audit-content.ts",
    "migrate:content": "node scripts/migrate-legacy-content.mjs",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "config:extract": "node --experimental-strip-types scripts/config-extract.mjs",
    "config:apply": "node scripts/config-apply.mjs"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ],
    "overrides": {
      "esbuild": "0.28.1",
      "volar-service-yaml": "0.0.71"
    }
  },
  "devDependencies": {
    "better-sqlite3": "^12.6.2",
    "bson": "^7.2.0",
    "prettier": "latest",
    "prettier-plugin-astro": "latest",
    "tar": "^7.5.16"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/mdx": "^6.0.3",
    "@astrojs/node": "^10.1.4",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@rowanmanning/feed-parser": "^2.1.3",
    "@waline/client": "^3.15.2",
    "astro": "^6.4.8",
    "astro-auto-import": "^0.5.1",
    "astro-loader-bluesky-posts": "^1.2.4",
    "astro-loader-github-prs": "^2.0.0",
    "astro-robots-txt": "^1.0.0",
    "katex": "^0.16.10",
    "lucide-static": "^0.562.0",
    "rehype-katex": "^7.0.0",
    "remark-directive": "^4.0.0",
    "remark-math": "^6.0.0",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5"
  }
