{
  "name": "Astro-star",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "astro dev",
    "prebuild": "node --experimental-strip-types scripts/generate-git-timestamps.ts",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "astro": "astro",
    "algolia:sync": "node --experimental-strip-types scripts/sync-algolia-index.ts",
    "migrate:content": "node scripts/migrate-legacy-content.mjs",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "config:extract": "node --experimental-strip-types scripts/config-extract.mjs",
    "config:apply": "node scripts/config-apply.mjs"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "devDependencies": {
    "better-sqlite3": "^12.6.2",
    "bson": "^7.2.0",
    "prettier": "latest",
    "prettier-plugin-astro": "latest",
    "tar": "^7.5.11"
  },
  "dependencies": {
    "@ascorbic/feed-loader": "^2.0.1",
    "@astrojs/check": "^0.9.6",
    "@astrojs/markdown-remark": "^6.3.10",
    "@astrojs/mdx": "^4.3.4",
    "@astrojs/node": "^9.4.3",
    "@astrojs/rss": "^4.0.14",
    "@astrojs/sitemap": "^3.6.0",
    "@waline/client": "^3.13.0",
    "astro": "^5.16.6",
    "astro-auto-import": "^0.5.1",
    "astro-loader-bluesky-posts": "^1.2.3",
    "astro-loader-github-prs": "^1.3.1",
    "astro-robots-txt": "^1.0.0",
    "katex": "^0.16.10",
    "lucide-static": "^0.562.0",
    "rehype-katex": "^7.0.0",
    "remark-directive": "^4.0.0",
    "remark-math": "^6.0.0",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5"
  }
