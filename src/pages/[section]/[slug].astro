---
import { getCollection, render } from "astro:content";
import ArticleDetailPage from "../../components/content/ArticleDetailPage.astro";
import { site } from "../../config/site";
import { getAdjacentArticles } from "../../utils/adjacent-articles";
import { resolveContentDates } from "../../utils/content-dates";
import { resolveContentDescription } from "../../utils/content-description";
import { resolveContentImage } from "../../utils/content-image";
import { resolveContentSlug } from "../../utils/content-slug";
import {
  formatContentDateTime,
  toContentIsoString,
} from "../../utils/content-time-zone";
import { resolveContentTitle } from "../../utils/content-title";
import { isPublishedContentEntry } from "../../utils/content-visibility";
import { getGitTimestamps } from "../../utils/git-timestamps";
import { getWalineServerURL } from "../../utils/waline-server-url";

const validSections = ["blog", "note", "project"] as const;
type SectionKey = (typeof validSections)[number];

export const prerender = true;

export async function getStaticPaths() {
  const sections = ["blog", "note", "project"] as const;
  const sectionEntries = await Promise.all(
    sections.map(async (section) => {
      const entries = (await getCollection(section)).filter(
        isPublishedContentEntry,
      );

      return entries.map((entry) => ({
        params: {
          section,
          slug: resolveContentSlug(entry.id, entry.data.routeSlug),
        },
      }));
    }),
  );

  return sectionEntries.flat();
}

const { section, slug } = Astro.params;

if (!section || !slug || !validSections.includes(section as SectionKey)) {
  return new Response(null, {
    status: 404,
    statusText: "Not found",
  });
}

const sectionKey = section as SectionKey;
const collectionEntries = (await getCollection(sectionKey)).filter(
  isPublishedContentEntry,
);
const articleEntry = collectionEntries.find(
  (entry) => resolveContentSlug(entry.id, entry.data.routeSlug) === slug,
);

if (!articleEntry) {
  return new Response(null, {
    status: 404,
    statusText: "Not found",
  });
}

const { Content, headings } = await render(articleEntry);
const articleSource = articleEntry.body ?? "";
const title = resolveContentTitle(articleEntry.id, articleEntry.data.title);
const description = resolveContentDescription(
  articleSource,
  articleEntry.data.description,
  site.site.description,
);
const articleType =
  (articleEntry.data as { type?: string }).type?.trim() || "Uncategorized";
const projectUrl =
  sectionKey === "project"
    ? (articleEntry.data as { projectUrl?: string }).projectUrl?.trim() || ""
    : "";
const docUrl =
  sectionKey === "project"
    ? (articleEntry.data as { docUrl?: string }).docUrl?.trim() || ""
    : "";
const author = site.profile.name;
const walineServerURL = getWalineServerURL();
const articleRoutePath = `/${section}/${slug}/`;
const contentPath =
  articleEntry.filePath ?? `src/content/${section}/${articleEntry.id}.mdx`;
const { createdAt: gitCreatedAt, updatedAt: gitUpdatedAt } =
  getGitTimestamps(contentPath);
const { createdAt, updatedAt } = resolveContentDates(articleEntry.data, {
  createdAt: gitCreatedAt,
  updatedAt: gitUpdatedAt,
});

const { previousArticle, nextArticle } = getAdjacentArticles(
  sectionKey,
  collectionEntries,
  articleEntry.id,
);

const formatDateTime = (value: Date | null) => {
  if (!value || Number.isNaN(value.getTime())) return "Unknown";

  return formatContentDateTime(value);
};

const countWords = (source: string) => {
  const body = source
    .replace(/^---[\s\S]*?---\s*/u, "")
    .replace(/^\s*(import|export)\s.+$/gmu, " ")
    .replace(/```[^\n\r]*[\r]?\n/g, " ")
    .replace(/```/g, " ")
    .replace(/`([^`]*)`/g, "$1")
    .replace(/!\[[^\]]*\]\([^)]*\)/g, " ")
    .replace(/\[([^\]]+)\]\([^)]*\)/g, "$1")
    .replace(/<[^>]+>/g, " ")
    .replace(/[>#*_~|-]/g, " ")
    .replace(/\s+/g, " ")
    .trim();

  const cjkUnits = body.match(
    /[\p{Script=Han}\p{Script=Hiragana}\p{Script=Katakana}\p{Script=Hangul}]/gu,
  );
  const nonCjkBody = body.replace(
    /[\p{Script=Han}\p{Script=Hiragana}\p{Script=Katakana}\p{Script=Hangul}]/gu,
    " ",
  );
  const latinWords = nonCjkBody.match(
    /[\p{Letter}\p{Number}]+(?:[._'-][\p{Letter}\p{Number}]+)*/gu,
  );

  return (cjkUnits?.length ?? 0) + (latinWords?.length ?? 0);
};

const stripNonContentBlocks = (source: string) =>
  source.replace(/^---[\s\S]*?---\s*/u, "").replace(/```[\s\S]*?```/g, "");

const hasMathSyntax = (source: string) => {
  const contentSource = stripNonContentBlocks(source);
  return /\$\$|\\\[|\\\(|\\begin\{|(^|[^$])\$[^$\n]+\$(?!\$)/m.test(
    contentSource,
  );
};

const articleWordCount = countWords(articleSource);
const includeKatexStyles = hasMathSyntax(articleSource);
const canonicalUrl = new URL(articleRoutePath, site.site.url).toString();
const imageUrl = new URL(
  resolveContentImage(
    articleSource,
    articleEntry.data.image,
    site.site.iconSrc,
  ),
  site.site.url,
).toString();
const createdAtIso = createdAt ? toContentIsoString(createdAt) : "";
const updatedAtIso = updatedAt ? toContentIsoString(updatedAt) : "";
const tocHeadings = headings
  .filter((heading) => heading.depth >= 1 && heading.depth <= 5)
  .map((heading) => ({
    depth: heading.depth as 1 | 2 | 3 | 4 | 5,
    slug: heading.slug,
    text: heading.text,
  }));
---

<ArticleDetailPage
  section={section}
  title={title}
  description={description}
  articleType={articleType}
  author={author}
  articleRoutePath={articleRoutePath}
  walineServerURL={walineServerURL}
  createdLabel={formatDateTime(createdAt)}
  updatedLabel={formatDateTime(updatedAt)}
  createdAtIso={createdAtIso}
  updatedAtIso={updatedAtIso}
  articleWordCount={articleWordCount}
  previousArticle={previousArticle}
  nextArticle={nextArticle}
  tocHeadings={tocHeadings}
  ArticleContent={Content}
  canonicalUrl={canonicalUrl}
  imageUrl={imageUrl}
  projectUrl={projectUrl}
  docUrl={docUrl}
  siteName={site.site.name}
  includeKatexStyles={includeKatexStyles}
/>
