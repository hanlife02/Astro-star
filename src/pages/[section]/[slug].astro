---
import ArticleDetailPage from "../../components/content/ArticleDetailPage.astro";
import CommentSection from "../../components/content/CommentSection.astro";
import Icon from "../../components/ui/Icon.astro";
import { Heart, MessageCircleReply } from "lucide-static";
import { site } from "../../config/site";
import { resolveContentDates } from "../../utils/content-dates";
import { resolveContentSlug } from "../../utils/content-slug";
import { resolveContentTitle } from "../../utils/content-title";
import { getGitTimestamps } from "../../utils/git-timestamps";
import { extractTocHeadings } from "../../utils/toc";

interface ContentModule {
  default: any;
  frontmatter?: {
    createdAt?: string | Date;
    updatedAt?: string | Date;
    routeSlug?: string;
    type?: string;
    title?: string;
    description?: string;
  };
}

const articleModules = import.meta.glob("../../content/{blog,note,project}/**/*.{md,mdx}", {
  eager: true,
});

const articleRawModules = import.meta.glob("../../content/{blog,note,project}/**/*.{md,mdx}", {
  eager: true,
  query: "?raw",
  import: "default",
});

const validSections = ["blog", "note", "project"] as const;

const { section, slug } = Astro.params;
const articleEntry = Object.entries(articleModules).find(([path, mod]) => {
  const match = path.match(/^\.\.\/\.\.\/content\/(blog|note|project)\/.+\.(md|mdx)$/i);
  if (!match || match[1] !== section) return false;
  return resolveContentSlug(path, (mod as ContentModule).frontmatter?.routeSlug) === slug;
});

if (!section || !slug || !validSections.includes(section as (typeof validSections)[number]) || !articleEntry) {
  return new Response(null, {
    status: 404,
    statusText: "Not found",
  });
}

const [articlePath, articleModule] = articleEntry as [string, ContentModule];
const articleRawSource = articleRawModules[articlePath] as string | undefined;

const ArticleContent = articleModule.default;
const title = resolveContentTitle(articlePath, articleModule.frontmatter?.title);
const description = articleModule.frontmatter?.description?.trim() || "";
const articleType = articleModule.frontmatter?.type?.trim() || "Uncategorized";
const author = site.owner.name;
const walineServerURL = import.meta.env.PUBLIC_WALINE_SERVER_URL?.trim() || "";
const articleRoutePath = `/${section}/${slug}/`;
const showComments = section === "blog" || section === "note";
const { createdAt: gitCreatedAt, updatedAt: gitUpdatedAt } = getGitTimestamps(new URL(articlePath, import.meta.url));
const { createdAt, updatedAt } = resolveContentDates(articleModule.frontmatter, {
  createdAt: gitCreatedAt,
  updatedAt: gitUpdatedAt,
});

const formatDateTime = (value: Date | null) => {
  if (!value || Number.isNaN(value.getTime())) return "Unknown";

  return new Intl.DateTimeFormat("en-US", {
    year: "numeric",
    month: "short",
    day: "2-digit",
    hour: "2-digit",
    minute: "2-digit",
    second: "2-digit",
    hour12: false,
  }).format(value);
};

const countWords = (source: string) => {
  const body = source
    .replace(/^---[\s\S]*?---\s*/u, "")
    .replace(/^\s*(import|export)\s.+$/gmu, " ")
    .replace(/```[^\n\r]*[\r]?\n/g, " ")
    .replace(/```/g, " ")
    .replace(/`([^`]*)`/g, "$1")
    .replace(/!\[[^\]]*\]\([^)]*\)/g, " ")
    .replace(/\[([^\]]+)\]\([^)]*\)/g, "$1")
    .replace(/<[^>]+>/g, " ")
    .replace(/[>#*_~|-]/g, " ")
    .replace(/\s+/g, " ")
    .trim();

  const cjkUnits = body.match(/[\p{Script=Han}\p{Script=Hiragana}\p{Script=Katakana}\p{Script=Hangul}]/gu);
  const nonCjkBody = body.replace(/[\p{Script=Han}\p{Script=Hiragana}\p{Script=Katakana}\p{Script=Hangul}]/gu, " ");
  const latinWords = nonCjkBody.match(/[\p{Letter}\p{Number}]+(?:[._'-][\p{Letter}\p{Number}]+)*/gu);

  return (cjkUnits?.length ?? 0) + (latinWords?.length ?? 0);
};

const articleWordCount = countWords(articleRawSource ?? "");
const tocHeadings = extractTocHeadings(articleRawSource ?? "");

const commentCount = 0;
---

<ArticleDetailPage
  section={section}
  title={title}
  description={description}
  articleType={articleType}
  author={author}
  articleRoutePath={articleRoutePath}
  walineServerURL={walineServerURL}
  createdLabel={formatDateTime(createdAt)}
  updatedLabel={formatDateTime(updatedAt)}
  articleWordCount={articleWordCount}
  tocHeadings={tocHeadings}
  ArticleContent={ArticleContent}
>
  {showComments && (
    <CommentSection
      slot="comments"
      ariaLabel="Comments"
      listAriaLabel="Comment list"
      formAriaLabel="Leave a comment"
    >
      <div slot="title">Comments</div>
      <div slot="meta">
        <span>{commentCount} Comments</span>
        <span class="comment-section__meta-divider" aria-hidden="true"></span>
        <button
          class="comment-section__sort-toggle"
          type="button"
          aria-live="polite"
          data-sort-state="newest"
          aria-label="Toggle comment sorting"
        >
          <span class="comment-section__sort-placeholder" aria-hidden="true">Hottest</span>
          <span class="comment-section__sort-face" data-sort-face="newest">Newest</span>
          <span class="comment-section__sort-face" data-sort-face="hottest">Hottest</span>
        </button>
      </div>
      <div slot="empty">No comments yet. Be the first to share a thought.</div>
      <form slot="form" class="comment-form" autocomplete="off">
        <div class="comment-form__field">
          <label class="comment-form__label" for="comment-name">Name</label>
          <input
            class="comment-form__input"
            id="comment-name"
            name="name"
            type="text"
            placeholder="Your name"
          />
        </div>
        <div class="comment-form__field">
          <label class="comment-form__label" for="comment-message">Comment</label>
          <textarea
            class="comment-form__textarea"
            id="comment-message"
            name="message"
            placeholder="Write your comment here..."
          ></textarea>
        </div>
        <div class="comment-form__actions">
          <button class="comment-form__submit" type="button">Post Comment</button>
        </div>
      </form>
      <script is:inline slot="footer">
        const sortToggle = document.querySelector('[data-sort-state]');
        if (sortToggle instanceof HTMLButtonElement) {
          sortToggle.addEventListener('click', () => {
            sortToggle.dataset.sortState =
              sortToggle.dataset.sortState === 'newest' ? 'hottest' : 'newest';
          });
        }
      </script>
    </CommentSection>
  )}
</ArticleDetailPage>
