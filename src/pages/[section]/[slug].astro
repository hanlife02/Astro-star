---
import { getCollection, render } from "astro:content";
import ArticleDetailPage from "../../components/content/ArticleDetailPage.astro";
import { PUBLIC_WALINE_SERVER_URL } from "astro:env/client";
import { site } from "../../config/site";
import { resolveContentDates } from "../../utils/content-dates";
import { resolveContentSlug } from "../../utils/content-slug";
import { resolveContentTitle } from "../../utils/content-title";
import { getGitTimestamps } from "../../utils/git-timestamps";

const validSections = ["blog", "note", "project"] as const;
type SectionKey = (typeof validSections)[number];

const { section, slug } = Astro.params;

if (!section || !slug || !validSections.includes(section as SectionKey)) {
  return new Response(null, {
    status: 404,
    statusText: "Not found",
  });
}

const sectionKey = section as SectionKey;
const collectionEntries = await getCollection(sectionKey);
const articleEntry = collectionEntries.find((entry) => resolveContentSlug(entry.id, entry.data.routeSlug) === slug);

if (!articleEntry) {
  return new Response(null, {
    status: 404,
    statusText: "Not found",
  });
}

const { Content, headings } = await render(articleEntry);
const articleSource = articleEntry.body ?? "";
const title = resolveContentTitle(articleEntry.id, articleEntry.data.title);
const description = articleEntry.data.description?.trim() || "";
const articleType = articleEntry.data.type?.trim() || "Uncategorized";
const author = site.owner.name;
const walineServerURL = PUBLIC_WALINE_SERVER_URL?.trim() || "";
const articleRoutePath = `/${section}/${slug}/`;
const entryFilePath = articleEntry.filePath
  ? new URL(`../../../${articleEntry.filePath}`, import.meta.url)
  : new URL(`../../content/${section}/${articleEntry.id}.mdx`, import.meta.url);
const { createdAt: gitCreatedAt, updatedAt: gitUpdatedAt } = getGitTimestamps(entryFilePath);
const { createdAt, updatedAt } = resolveContentDates(articleEntry.data, {
  createdAt: gitCreatedAt,
  updatedAt: gitUpdatedAt,
});

const formatDateTime = (value: Date | null) => {
  if (!value || Number.isNaN(value.getTime())) return "Unknown";

  return new Intl.DateTimeFormat("en-US", {
    year: "numeric",
    month: "short",
    day: "2-digit",
    hour: "2-digit",
    minute: "2-digit",
    second: "2-digit",
    hour12: false,
  }).format(value);
};

const countWords = (source: string) => {
  const body = source
    .replace(/^---[\s\S]*?---\s*/u, "")
    .replace(/^\s*(import|export)\s.+$/gmu, " ")
    .replace(/```[^\n\r]*[\r]?\n/g, " ")
    .replace(/```/g, " ")
    .replace(/`([^`]*)`/g, "$1")
    .replace(/!\[[^\]]*\]\([^)]*\)/g, " ")
    .replace(/\[([^\]]+)\]\([^)]*\)/g, "$1")
    .replace(/<[^>]+>/g, " ")
    .replace(/[>#*_~|-]/g, " ")
    .replace(/\s+/g, " ")
    .trim();

  const cjkUnits = body.match(/[\p{Script=Han}\p{Script=Hiragana}\p{Script=Katakana}\p{Script=Hangul}]/gu);
  const nonCjkBody = body.replace(/[\p{Script=Han}\p{Script=Hiragana}\p{Script=Katakana}\p{Script=Hangul}]/gu, " ");
  const latinWords = nonCjkBody.match(/[\p{Letter}\p{Number}]+(?:[._'-][\p{Letter}\p{Number}]+)*/gu);

  return (cjkUnits?.length ?? 0) + (latinWords?.length ?? 0);
};

const articleWordCount = countWords(articleSource);
const tocHeadings = headings
  .filter((heading) => heading.depth >= 1 && heading.depth <= 3)
  .map((heading) => ({
    depth: heading.depth as 1 | 2 | 3,
    slug: heading.slug,
    text: heading.text,
  }));
---

<ArticleDetailPage
  section={section}
  title={title}
  description={description}
  articleType={articleType}
  author={author}
  articleRoutePath={articleRoutePath}
  walineServerURL={walineServerURL}
  createdLabel={formatDateTime(createdAt)}
  updatedLabel={formatDateTime(updatedAt)}
  articleWordCount={articleWordCount}
  tocHeadings={tocHeadings}
  ArticleContent={Content}
/>
