---
import ArticleDetailPage from "../../components/content/ArticleDetailPage.astro";
import { site } from "../../config/site";
import { resolveContentDates } from "../../utils/content-dates";
import { resolveContentSlug } from "../../utils/content-slug";
import { resolveContentTitle } from "../../utils/content-title";
import { getGitTimestamps } from "../../utils/git-timestamps";
import { extractTocHeadings, type TocHeading } from "../../utils/toc";

interface ContentModule {
  default: any;
  frontmatter?: {
    createdAt?: string | Date;
    updatedAt?: string | Date;
    routeSlug?: string;
    type?: string;
    title?: string;
    description?: string;
  };
}

const articleModules = import.meta.glob("../../content/{blog,note,project}/*.{md,mdx}", {
  eager: true,
});

const articleRawModules = import.meta.glob("../../content/{blog,note,project}/*.{md,mdx}", {
  eager: true,
  query: "?raw",
  import: "default",
});

export function getStaticPaths() {
  const articleEntries = Object.entries(
    import.meta.glob("../../content/{blog,note,project}/*.{md,mdx}", { eager: true }),
  ) as Array<[string, ContentModule]>;

  return articleEntries
    .map(([path, mod]) => {
      const match = path.match(/^\.\.\/\.\.\/content\/(blog|note|project)\/([^/]+)\.(md|mdx)$/i);
      if (!match) return null;

      const routeSlug = resolveContentSlug(path, mod.frontmatter?.routeSlug);

      return {
        params: {
          section: match[1],
          slug: routeSlug,
        },
        props: {
          articlePath: path,
        },
      };
    })
    .filter((item): item is { params: { section: string; slug: string }; props: { articlePath: string } } => item !== null);
}

const { section, slug } = Astro.params;
const { articlePath } = Astro.props as { articlePath: string };
const articleModule = articleModules[articlePath] as ContentModule | undefined;
const articleRawSource = articleRawModules[articlePath] as string | undefined;

if (!articleModule || !section || !slug) {
  throw new Error("Missing article content module.");
}

const ArticleContent = articleModule.default;
const title = resolveContentTitle(articlePath, articleModule.frontmatter?.title);
const description = articleModule.frontmatter?.description?.trim() || "";
const articleType = articleModule.frontmatter?.type?.trim() || "Uncategorized";
const author = site.owner.name;
const walineServerURL = import.meta.env.PUBLIC_WALINE_SERVER_URL?.trim() || "";
const articleRoutePath = `/${section}/${slug}/`;
const { createdAt: gitCreatedAt, updatedAt: gitUpdatedAt } = getGitTimestamps(new URL(articlePath, import.meta.url));
const { createdAt, updatedAt } = resolveContentDates(articleModule.frontmatter, {
  createdAt: gitCreatedAt,
  updatedAt: gitUpdatedAt,
});

const formatDateTime = (value: Date | null) => {
  if (!value || Number.isNaN(value.getTime())) return "Unknown";

  return new Intl.DateTimeFormat("en-US", {
    year: "numeric",
    month: "short",
    day: "2-digit",
    hour: "2-digit",
    minute: "2-digit",
    second: "2-digit",
    hour12: false,
  }).format(value);
};

const countWords = (source: string) => {
  const body = source
    .replace(/^---[\s\S]*?---\s*/u, "")
    .replace(/```[\s\S]*?```/g, " ")
    .replace(/`[^`]*`/g, " ")
    .replace(/!\[[^\]]*\]\([^)]*\)/g, " ")
    .replace(/\[([^\]]+)\]\([^)]*\)/g, "$1")
    .replace(/<[^>]+>/g, " ")
    .replace(/[>#*_~|-]/g, " ");

  const words = body.match(/[\p{Letter}\p{Number}]+/gu);
  return words?.length ?? 0;
};

const articleWordCount = countWords(articleRawSource ?? "");
const tocHeadings = extractTocHeadings(articleRawSource ?? "");
---

<ArticleDetailPage
  section={section}
  title={title}
  description={description}
  articleType={articleType}
  author={author}
  articleRoutePath={articleRoutePath}
  walineServerURL={walineServerURL}
  createdLabel={formatDateTime(createdAt)}
  updatedLabel={formatDateTime(updatedAt)}
  articleWordCount={articleWordCount}
  tocHeadings={tocHeadings}
  ArticleContent={ArticleContent}
/>
