---
import DocumentPageShell from "../components/layout/DocumentPageShell.astro";
import WalineComments from "../components/content/WalineComments.astro";
import { PUBLIC_WALINE_SERVER_URL } from "astro:env/client";
import { extractTocHeadings } from "../utils/toc";
import "../style/pages/content-page.css";
import "../style/components/content/article-detail-page.css";

interface ContentModule {
  default: any;
  frontmatter?: {
    title?: string;
  };
}

const linksModule = import.meta.glob("../content/links/links.mdx", {
  eager: true,
})["../content/links/links.mdx"] as ContentModule | undefined;

const linksRawSource = import.meta.glob("../content/links/links.mdx", {
  eager: true,
  query: "?raw",
  import: "default",
})["../content/links/links.mdx"] as string | undefined;

if (!linksModule) {
  throw new Error("Missing src/content/links/links.mdx");
}

const LinksContent = linksModule.default;
const tocHeadings = extractTocHeadings(linksRawSource ?? "");
const walineServerURL = PUBLIC_WALINE_SERVER_URL?.trim() || "";
---

<DocumentPageShell
  background="constellation"
  contentClass="content-page content-page--links"
  contentAriaLabel="Links content"
  tocAriaLabel="Links table of contents"
  tocItems={tocHeadings.map((heading) => ({
    href: `#${heading.slug}`,
    label: heading.text,
    depth: heading.depth,
  }))}
>
  <LinksContent />
  <WalineComments articleRoutePath="/links/" walineServerURL={walineServerURL} />
</DocumentPageShell>
