---
import HomeLayout from "../layouts/HomeLayout.astro";
import Signature from "../components/home/signature.astro";
import FooterMeta from "../components/common/FooterMeta.astro";
import { extractTocHeadings, type TocHeading } from "../utils/toc";
import "../style/pages/content-page.css";

interface ContentModule {
  default: unknown;
  frontmatter?: {
    title?: string;
  };
}

const linksModule = import.meta.glob("../content/links/links.mdx", {
  eager: true,
})["../content/links/links.mdx"] as ContentModule | undefined;

const linksRawSource = import.meta.glob("../content/links/links.mdx", {
  eager: true,
  query: "?raw",
  import: "default",
})["../content/links/links.mdx"] as string | undefined;

if (!linksModule) {
  throw new Error("Missing src/content/links/links.mdx");
}

const LinksContent = linksModule.default;

const tocHeadings = extractTocHeadings(linksRawSource ?? "");
---

<HomeLayout mainCol2Fr="4fr" mainCol3Fr="1.5fr" variant="default" background="constellation">
  <Signature slot="signature" />

  <section slot="profile" class="content-page content-page--links" aria-label="Links content">
    <div class="content-page-body">
      <LinksContent />
    </div>
  </section>

  <aside slot="latest" class="content-toc" aria-label="Links table of contents">
    {
      tocHeadings.length > 0 ? (
        <ol class="content-toc-list">
          {tocHeadings.map((heading) => (
            <li
              class:list={[
                "content-toc-item",
                `content-toc-item--depth-${heading.depth}`,
              ]}
            >
              <a class={`content-toc-link content-toc-link--depth-${heading.depth}`} href={`#${heading.slug}`}>
                {heading.text}
              </a>
            </li>
          ))}
        </ol>
      ) : (
        <p class="content-toc-empty">No headings yet.</p>
      )
    }
  </aside>

  <FooterMeta slot="footer-info" />
</HomeLayout>

