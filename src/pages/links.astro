---
import DocumentPageShell from "../components/layout/DocumentPageShell.astro";
import WalineComments from "../components/content/WalineComments.astro";
import FriendLinksPanel from "../components/links/FriendLinksPanel.astro";
import LostLinksPanel from "../components/links/LostLinksPanel.astro";
import { WALINE_SERVER_URL } from "astro:env/server";
import { friendLinks, linksPage, lostLinks } from "../config/links";
import "../style/pages/content-page.css";
import "../style/components/content/article-detail-page.css";

const walineServerURL = WALINE_SERVER_URL?.trim() || "";

const tocItems = [
  { href: "#friends", label: linksPage.friendsTitle, depth: 2 as const },
  { href: "#lost", label: linksPage.lostTitle, depth: 2 as const },
  { href: "#apply", label: linksPage.applyTitle, depth: 2 as const },
];
---

<DocumentPageShell
  background="constellation"
  contentClass="content-page content-page--links"
  contentAriaLabel="Links content"
  tocAriaLabel="Links table of contents"
  tocItems={tocItems}
>
  <h1>{linksPage.title}</h1>
  <p>{linksPage.intro}</p>

  <h2 id="friends">{linksPage.friendsTitle}</h2>
  <FriendLinksPanel items={[...friendLinks].sort(() => Math.random() - 0.5)} />

  <h2 id="lost">{linksPage.lostTitle}</h2>
  <LostLinksPanel items={lostLinks} title={linksPage.lostTitle} />

  <h2 id="apply">{linksPage.applyTitle}</h2>
  {linksPage.applyRules.map((rule) => <p>{rule}</p>)}

  <WalineComments articleRoutePath="/links/" walineServerURL={walineServerURL} />
</DocumentPageShell>
