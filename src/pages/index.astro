---
import HomePageContent from "../components/home/HomePageContent.astro";
import { Github, Mail } from "lucide-static";
import { site } from "../config/site";
import { resolveContentTitle } from "../utils/content-title";
import { getGitTimestamps } from "../utils/git-timestamps";

const { profile, owner } = site;
const githubUsername = (profile.githubUsername || site.contact.githubUsername).trim();
const bilibiliId = profile.bilibiliId.trim();
const cloudMusicId = profile.cloudMusicId.trim();
const emailAddress = (profile.email || site.contact.email).trim();
const latestBlogSourceModules = import.meta.glob("../content/blog/*.{md,mdx}", { eager: true });
const latestNoteSourceModules = import.meta.glob("../content/note/*.{md,mdx}", { eager: true });

interface BlogModule {
  frontmatter?: {
    title?: string;
  };
}

interface LatestArticleItem {
  title: string;
  href: string;
  pubDateIso: string;
  createdAtIso: string;
  updatedAtIso: string;
  displayDate: string;
  year: string;
  timestamp: number;
}

interface LatestTimelineGroup {
  year: string;
  articles: LatestArticleItem[];
}

function buildLatestArticles(sourceModules: Record<string, unknown>, section: "blog" | "note") {
  return Object.entries(sourceModules)
  .map(([path, mod]) => {
    const frontmatter = (mod as BlogModule).frontmatter;
    const title = resolveContentTitle(path, frontmatter?.title);
    const slug = path.split("/").pop()?.replace(/\.(md|mdx)$/i, "");
    const { createdAt, updatedAt } = getGitTimestamps(new URL(path, import.meta.url));
    const pubDate = createdAt ?? updatedAt;

    if (!slug || !pubDate || Number.isNaN(pubDate.getTime())) return null;

    return {
      title,
      href: `/${section}/${slug}/`,
      pubDateIso: pubDate.toISOString(),
      createdAtIso: createdAt?.toISOString() ?? pubDate.toISOString(),
      updatedAtIso: updatedAt?.toISOString() ?? pubDate.toISOString(),
      displayDate: `${pubDate.toISOString().slice(5, 7)}.${pubDate.toISOString().slice(8, 10)}`,
      year: pubDate.toISOString().slice(0, 4),
      timestamp: pubDate.getTime(),
    } as LatestArticleItem;
  })
  .filter((item): item is LatestArticleItem => item !== null)
  .sort((a, b) => b.timestamp - a.timestamp);
}

function buildLatestTimelineGroups(latestArticles: LatestArticleItem[]) {
  return latestArticles.reduce<LatestTimelineGroup[]>((groups, article) => {
    const currentGroup = groups[groups.length - 1];

    if (currentGroup?.year === article.year) {
      currentGroup.articles.push(article);
      return groups;
    }

    groups.push({ year: article.year, articles: [article] });
    return groups;
  }, []);
}

const latestBlogArticles = buildLatestArticles(latestBlogSourceModules, "blog").slice(0, 4);
const latestNoteArticles = buildLatestArticles(latestNoteSourceModules, "note").slice(0, 4);
const latestAnimationOrderMap = new Map(
  [...latestBlogArticles, ...latestNoteArticles].map((article, index) => [article.href, index]),
);
const latestBlogTimelineGroups = buildLatestTimelineGroups(latestBlogArticles);
const latestNoteTimelineGroups = buildLatestTimelineGroups(latestNoteArticles);

const profileLinks = [
  {
    key: "github",
    label: "GitHub",
    href: githubUsername ? `https://github.com/${encodeURIComponent(githubUsername)}` : "",
    icon: Github,
    external: true,
  },
  {
    key: "bilibili",
    label: "Bilibili",
    href: bilibiliId ? `https://space.bilibili.com/${encodeURIComponent(bilibiliId)}` : "",
    icon: "",
    external: true,
  },
  {
    key: "cloud-music",
    label: "NetEase Cloud Music",
    href: cloudMusicId
      ? `https://music.163.com/#/user/home?id=${encodeURIComponent(cloudMusicId)}`
      : "",
    icon: "",
    external: true,
  },
  {
    key: "email",
    label: "Email",
    href: emailAddress ? `mailto:${emailAddress}` : "",
    icon: Mail,
    external: false,
  },
]
  .filter((item) => item.href)
  .slice(0, 4);
---

<HomePageContent
  profile={profile}
  ownerName={owner.name}
  profileLinks={profileLinks}
  latestBlogTimelineGroups={latestBlogTimelineGroups}
  latestNoteTimelineGroups={latestNoteTimelineGroups}
  latestAnimationOrderMap={latestAnimationOrderMap}
/>
