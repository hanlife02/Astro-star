---
import { getCollection, render } from "astro:content";
import { WALINE_SERVER_URL } from "astro:env/server";
import DocumentDetailPage from "../components/content/DocumentDetailPage.astro";
import WalineComments from "../components/content/WalineComments.astro";
import { site } from "../config/site";

export const prerender = true;

const pageEntry = (await getCollection("page")).find(
  (entry) => entry.id === "about",
);

if (!pageEntry) {
  return new Response(null, {
    status: 404,
    statusText: "Not found",
  });
}

const { Content, headings } = await render(pageEntry);
const title = pageEntry.data.title;
const description = pageEntry.data.description || site.site.description;
const pageRoutePath = "/about/";
const canonicalUrl = new URL(pageRoutePath, site.site.url).toString();
const walineServerURL = WALINE_SERVER_URL?.trim() || "";
const tocHeadings = headings
  .filter((heading) => heading.depth >= 1 && heading.depth <= 5)
  .map((heading) => ({
    depth: heading.depth as 1 | 2 | 3 | 4 | 5,
    slug: heading.slug,
    text: heading.text,
  }));
---

<DocumentDetailPage
  background={pageEntry.data.background ?? "code-rain"}
  title={`${title} - ${site.site.name}`}
  description={description}
  canonicalUrl={canonicalUrl}
  ogTitle={title}
  ogType="website"
  contentClass="content-page content-page--article"
  contentAriaLabel="About content"
  tocAriaLabel="About table of contents"
  tocTitle={pageEntry.data.tocTitle}
  tocHeadings={tocHeadings}
  DocumentContent={Content}
>
  <WalineComments
    slot="after-content"
    articleRoutePath={pageRoutePath}
    walineServerURL={walineServerURL}
  />
</DocumentDetailPage>
