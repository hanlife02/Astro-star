---
import DocumentPageShell from "../components/layout/DocumentPageShell.astro";
import WalineComments from "../components/content/WalineComments.astro";
import AppPanelCard from "../components/ui/AppPanelCard.astro";
import { WALINE_SERVER_URL } from "astro:env/server";
import { aboutPage } from "../config/about";

const walineServerURL = WALINE_SERVER_URL?.trim() || "";
const tocItems = [
  { href: "#intro", label: aboutPage.introTitle, depth: 2 as const },
  { href: "#social", label: aboutPage.socialTitle, depth: 2 as const },
  { href: "#tools", label: aboutPage.toolsTitle, depth: 2 as const },
  { href: "#timeline", label: aboutPage.timelineTitle, depth: 2 as const },
];
---

<DocumentPageShell
  background="code-rain"
  contentAriaLabel="About content"
  tocAriaLabel="About table of contents"
  tocTitle="Contents"
  tocItems={tocItems}
>
  <h1>{aboutPage.title}</h1>

  <h2 id="intro">{aboutPage.introTitle}</h2>
  {aboutPage.introParagraphs.map((paragraph) => <p>{paragraph}</p>)}

  <h2 id="social">{aboutPage.socialTitle}</h2>
  <AppPanelCard items={[...aboutPage.socialItems]} />

  <h2 id="tools">{aboutPage.toolsTitle}</h2>
  <AppPanelCard items={[...aboutPage.toolItems]} />

  <h1>{aboutPage.blogTitle}</h1>
  <h2 id="timeline">{aboutPage.timelineTitle}</h2>
  {
    aboutPage.timeline.map((year) => (
      <>
        <p>
          <em>{year.label}</em>
        </p>
        {year.events.map((event) => <blockquote><p>{event}</p></blockquote>)}
        {year.summary && <p>{year.summary}</p>}
      </>
    ))
  }

  <WalineComments articleRoutePath="/about/" walineServerURL={walineServerURL} />
</DocumentPageShell>
