---
import DocumentPageShell from "../components/layout/DocumentPageShell.astro";
import WalineComments from "../components/content/WalineComments.astro";
import { aboutPage } from "../config/about";
import { site } from "../config/site";

export const prerender = true;

const walineServerURL = "";
const pageDescription = aboutPage.introParagraphs.join(" ");
const tocItems = [
  { href: "#intro", label: aboutPage.title, depth: 2 as const },
  { href: "#timeline", label: aboutPage.timelineTitle, depth: 2 as const },
];
---

<DocumentPageShell
  background="code-rain"
  title={`${aboutPage.title} - ${site.site.name}`}
  description={pageDescription}
  ogTitle={aboutPage.title}
  contentAriaLabel="About content"
  tocAriaLabel="About table of contents"
  tocTitle="Contents"
  tocItems={tocItems}
>
  <h1>About</h1>

  <h2 id="intro">{aboutPage.title}</h2>
  {aboutPage.introParagraphs.map((paragraph) => <p>{paragraph}</p>)}

  <h2>{aboutPage.blogTitle}</h2>
  <h2 id="timeline">{aboutPage.timelineTitle}</h2>
  {
    aboutPage.timeline.map((year) => (
      <>
        <p>
          <em>{year.label}</em>
        </p>
        {year.events.map((event) => (
          <blockquote>
            <p>{event}</p>
          </blockquote>
        ))}
        {year.summary && <p>{year.summary}</p>}
      </>
    ))
  }

  <WalineComments walineServerURL={walineServerURL} />
</DocumentPageShell>
