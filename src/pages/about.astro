---
import DocumentPageShell from "../components/layout/DocumentPageShell.astro";
import WalineComments from "../components/content/WalineComments.astro";
import { PUBLIC_WALINE_SERVER_URL } from "astro:env/client";
import { extractTocHeadings } from "../utils/toc";
import "../style/pages/content-page.css";
import "../style/components/content/article-detail-page.css";

interface ContentModule {
  default: any;
  frontmatter?: {
    title?: string;
  };
}

const aboutModule = import.meta.glob("../content/about/about.mdx", {
  eager: true,
})["../content/about/about.mdx"] as ContentModule | undefined;

const aboutRawSource = import.meta.glob("../content/about/about.mdx", {
  eager: true,
  query: "?raw",
  import: "default",
})["../content/about/about.mdx"] as string | undefined;

if (!aboutModule) {
  throw new Error("Missing src/content/about/about.mdx");
}

const AboutContent = aboutModule.default;
const tocHeadings = extractTocHeadings(aboutRawSource ?? "");
const walineServerURL = PUBLIC_WALINE_SERVER_URL?.trim() || "";
---

<DocumentPageShell
  background="code-rain"
  contentAriaLabel="About content"
  tocAriaLabel="About table of contents"
  tocTitle="Contents"
  tocItems={tocHeadings.map((heading) => ({
    href: `#${heading.slug}`,
    label: heading.text,
    depth: heading.depth,
  }))}
>
  <AboutContent />
  <WalineComments articleRoutePath="/about/" walineServerURL={walineServerURL} />
</DocumentPageShell>
