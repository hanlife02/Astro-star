---
import { getCollection, render } from "astro:content";
import DocumentDetailPage from "../components/content/DocumentDetailPage.astro";
import WalineComments from "../components/content/WalineComments.astro";
import { site } from "../config/site";
import { getWalineServerURL } from "../utils/waline-server-url";

export const prerender = true;

const pageEntry = (await getCollection("page")).find(
  (entry) => entry.id === "about",
);

if (!pageEntry) {
  return new Response(null, {
    status: 404,
    statusText: "Not found",
  });
}

const { Content, headings } = await render(pageEntry);
const title = pageEntry.data.title;
const description = pageEntry.data.description || site.site.description;
const contentTitle = pageEntry.data.heading || title;
const contentTitleId = pageEntry.id;
const pageRoutePath = "/about/";
const canonicalUrl = new URL(pageRoutePath, site.site.url).toString();
const walineServerURL = getWalineServerURL();
const tocHeadings = [
  {
    depth: 1 as const,
    slug: contentTitleId,
    text: contentTitle,
  },
  ...headings.filter((heading) => heading.depth >= 2 && heading.depth <= 5),
].map((heading) => ({
  depth: heading.depth as 1 | 2 | 3 | 4 | 5,
  slug: heading.slug,
  text: heading.text,
}));
---

<DocumentDetailPage
  background={pageEntry.data.background ?? "code-rain"}
  title={`${title} - ${site.site.name}`}
  contentTitle={contentTitle}
  contentTitleId={contentTitleId}
  contentDescription={pageEntry.data.description}
  description={description}
  canonicalUrl={canonicalUrl}
  ogTitle={title}
  ogType="website"
  contentClass="content-page content-page--article content-page--about"
  contentAriaLabel="About content"
  tocAriaLabel="About table of contents"
  tocTitle={pageEntry.data.tocTitle}
  tocHeadings={tocHeadings}
  DocumentContent={Content}
>
  <WalineComments
    slot="after-content"
    articleRoutePath={pageRoutePath}
    walineServerURL={walineServerURL}
  />
</DocumentDetailPage>
