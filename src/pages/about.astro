---
import HomeLayout from "../layouts/HomeLayout.astro";
import Signature from "../components/home/signature.astro";
import FooterMeta from "../components/common/FooterMeta.astro";
import { extractTocHeadings, type TocHeading } from "../utils/toc";
import "../style/pages/content-page.css";

interface ContentModule {
  default: unknown;
  frontmatter?: {
    title?: string;
  };
}

const aboutModule = import.meta.glob("../content/about/about.mdx", {
  eager: true,
})["../content/about/about.mdx"] as ContentModule | undefined;

const aboutRawSource = import.meta.glob("../content/about/about.mdx", {
  eager: true,
  query: "?raw",
  import: "default",
})["../content/about/about.mdx"] as string | undefined;

if (!aboutModule) {
  throw new Error("Missing src/content/about/about.mdx");
}

const AboutContent = aboutModule.default;

const tocHeadings = extractTocHeadings(aboutRawSource ?? "");
---

<HomeLayout mainCol2Fr="4fr" mainCol3Fr="1.5fr" variant="default" background="code-rain">
  <Signature slot="signature" />

  <section slot="profile" class="content-page" aria-label="About content">
    <div class="content-page-body">
      <AboutContent />
    </div>
  </section>

  <aside slot="latest" class="content-toc" aria-label="About table of contents">
    {
      tocHeadings.length > 0 ? (
        <>
          <p class="content-toc-title">Contents</p>
          <ol class="content-toc-list">
            {tocHeadings.map((heading) => (
              <li
                class:list={[
                  "content-toc-item",
                  `content-toc-item--depth-${heading.depth}`,
                ]}
              >
                <a class={`content-toc-link content-toc-link--depth-${heading.depth}`} href={`#${heading.slug}`}>
                  {heading.text}
                </a>
              </li>
            ))}
          </ol>
        </>
      ) : (
        <p class="content-toc-empty">No headings yet.</p>
      )
    }
  </aside>

  <FooterMeta slot="footer-info" />
</HomeLayout>
