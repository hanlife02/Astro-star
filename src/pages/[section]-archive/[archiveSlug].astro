---
import { getCollection } from "astro:content";
import SectionArchivePage from "../../components/content/SectionArchivePage.astro";
import { resolveContentDates } from "../../utils/content-dates";
import {
  normalizeArchiveSlug,
  resolveContentSlug,
  slugifyCategoryLabel,
} from "../../utils/content-slug";
import { getGitTimestamps } from "../../utils/git-timestamps";
import { resolveContentTitle } from "../../utils/content-title";

interface ContentEntryMeta {
  filePath?: string;
  id: string;
  data: {
    archiveSlug?: string;
    createdAt?: string | Date;
    routeSlug?: string | number;
    title?: string;
    type?: string;
    updatedAt?: string | Date;
  };
}

interface ArchiveArticleItem {
  createdAt: Date;
  createdLabel: string;
  href: string;
  title: string;
  year: string;
}

const sectionBaseLabels = {
  blog: "Blog",
  note: "Note",
  project: "Project",
} as const;

type SectionKey = keyof typeof sectionBaseLabels;

function getArchiveSlugFromEntryId(id: string) {
  return normalizeArchiveSlug(id.split("/").slice(0, -1).at(-1));
}

function getArchiveSlugFromEntry(section: SectionKey, entry: ContentEntryMeta) {
  const directoryArchiveSlug = getArchiveSlugFromEntryId(entry.id);
  const label = entry.data.type?.trim() || directoryArchiveSlug || "Uncategorized";

  return (
    (section === "blog" ? directoryArchiveSlug : "") ||
    normalizeArchiveSlug(entry.data.archiveSlug) ||
    directoryArchiveSlug ||
    slugifyCategoryLabel(label) ||
    "uncategorized"
  );
}

export async function getStaticPaths() {
  const archiveEntries = (
    await Promise.all(
      (Object.keys(sectionBaseLabels) as SectionKey[]).map(async (section) => {
        const collectionEntries = (await getCollection(section)) as ContentEntryMeta[];

        return collectionEntries.map((entry) => ({
          archiveSlug: getArchiveSlugFromEntry(section, entry),
          section,
        }));
      }),
    )
  ).flat();

  return Array.from(
    new Map(
      archiveEntries.map((item) => [`${item.section}:${item.archiveSlug}`, item]),
    ).values(),
  ).map((item) => ({
    params: {
      archiveSlug: item.archiveSlug,
      section: item.section,
    },
  }));
}

const { section, archiveSlug } = Astro.params;

if (!section || !(section in sectionBaseLabels) || !archiveSlug) {
  return new Response(null, {
    status: 404,
    statusText: "Not found",
  });
}

const sectionKey = section as SectionKey;
const collectionEntries = (await getCollection(sectionKey)) as ContentEntryMeta[];

const articles = collectionEntries
  .map((entry) => {
    const currentArchiveSlug = getArchiveSlugFromEntry(sectionKey, entry);
    if (currentArchiveSlug !== archiveSlug) return null;

    const routeSlug = resolveContentSlug(entry.id, entry.data.routeSlug);
    const title = resolveContentTitle(entry.id, entry.data.title);
    const contentPath = entry.filePath ?? `src/content/${section}/${entry.id}.mdx`;
    const { createdAt: gitCreatedAt, updatedAt: gitUpdatedAt } = getGitTimestamps(contentPath);
    const { createdAt, updatedAt } = resolveContentDates(entry.data, {
      createdAt: gitCreatedAt,
      updatedAt: gitUpdatedAt,
    });
    const publishedAt = createdAt ?? updatedAt;

    if (!publishedAt || Number.isNaN(publishedAt.getTime())) return null;

    return {
      createdAt: publishedAt,
      createdLabel: new Intl.DateTimeFormat("en-US", {
        year: "numeric",
        month: "short",
        day: "2-digit",
      }).format(publishedAt),
      href: `/${section}/${routeSlug}/`,
      title,
      year: publishedAt.toISOString().slice(0, 4),
    } satisfies ArchiveArticleItem;
  })
  .filter((item): item is ArchiveArticleItem => item !== null)
  .sort((a, b) => b.createdAt.getTime() - a.createdAt.getTime());

const yearGroups = articles.reduce<Array<{ articles: ArchiveArticleItem[]; year: string }>>((groups, article) => {
  const currentGroup = groups[groups.length - 1];

  if (currentGroup?.year === article.year) {
    currentGroup.articles.push(article);
    return groups;
  }

  groups.push({ year: article.year, articles: [article] });
  return groups;
}, []);

const sectionLabel = sectionBaseLabels[sectionKey];
const pageLabel = `${sectionLabel} Archive`;
---

<SectionArchivePage pageLabel={pageLabel} yearGroups={yearGroups} />
