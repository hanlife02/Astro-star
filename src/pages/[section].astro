---
import { getCollection } from "astro:content";
import SectionListingPage from "../components/content/SectionListingPage.astro";
import { normalizeArchiveSlug as normalizeContentArchiveSlug } from "../utils/content-slug";

interface SectionCategoryEntry {
  archiveSlug: string;
  count: number;
  href: string;
  label: string;
}

const sectionLabels = {
  blog: "Blog",
  note: "Note",
  project: "Project",
} as const;

function normalizeArchiveSlug(value?: unknown) {
  return normalizeContentArchiveSlug(value);
}

function getArchiveSlugFromEntryId(id: string) {
  return normalizeArchiveSlug(id.split("/").slice(0, -1).at(-1));
}

function getEntrySlug(id: string, routeSlug?: string | number) {
  return normalizeArchiveSlug(routeSlug) || id.split("/").at(-1) || "untitled";
}

function getEntryLabel(id: string, title?: string) {
  return title?.trim() || id.split("/").at(-1) || "Untitled";
}

function slugifyCategoryLabel(value: string) {
  return value
    .toLowerCase()
    .trim()
    .replace(/[`*_~()[\]{}]/g, "")
    .replace(/[^\p{Letter}\p{Number}\s-]/gu, "")
    .replace(/\s+/g, "-")
    .replace(/-+/g, "-")
    .replace(/^-|-$/g, "");
}

export function getStaticPaths() {
  return ["blog", "note", "project"].map((section) => ({
    params: { section },
  }));
}

const { section } = Astro.params;

if (!section || !(section in sectionLabels)) {
  throw new Error("Unsupported section.");
}

const sectionKey = section as keyof typeof sectionLabels;
const collectionEntries = await getCollection(sectionKey);

let categories: SectionCategoryEntry[] = [];

if (sectionKey === "project") {
  categories = collectionEntries
    .map((entry) => {
      const slug = getEntrySlug(entry.id, entry.data.routeSlug);

      return {
        archiveSlug: slug,
        count: 1,
        href: `/${section}/${slug}/`,
        label: getEntryLabel(entry.id, entry.data.title),
      };
    })
    .sort((a, b) => a.label.localeCompare(b.label, "en-US"));
} else {
  categories = collectionEntries
    .map((entry) => {
      const directoryArchiveSlug = getArchiveSlugFromEntryId(entry.id);
      const label = entry.data.type?.trim() || directoryArchiveSlug || "Uncategorized";
      const archiveSlug =
        (sectionKey === "blog" ? directoryArchiveSlug : "") ||
        normalizeArchiveSlug(entry.data.archiveSlug) ||
        directoryArchiveSlug ||
        slugifyCategoryLabel(label) ||
        "uncategorized";

      return {
        archiveSlug,
        label,
      };
    })
    .reduce<SectionCategoryEntry[]>((entries, item) => {
      const existingEntry = entries.find((entry) => entry.archiveSlug === item.archiveSlug);

      if (existingEntry) {
        existingEntry.count += 1;
        return entries;
      }

      entries.push({
        archiveSlug: item.archiveSlug,
        count: 1,
        href: `/${section}-archive/${item.archiveSlug}/`,
        label: item.label,
      });
      return entries;
    }, [])
    .sort((a, b) => a.label.localeCompare(b.label, "en-US"));
}

const pageLabel = sectionLabels[sectionKey];
const viewAllHref = `/${section}-archive/`;
const viewAllLabel = `View all ${pageLabel.toLowerCase()}s`;
---

<SectionListingPage
  categories={categories}
  pageLabel={pageLabel}
  showCounts={sectionKey !== "project"}
  viewAllHref={viewAllHref}
  viewAllLabel={viewAllLabel}
/>
