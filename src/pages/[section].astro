---
import SectionListingPage from "../components/content/SectionListingPage.astro";
import { getGitTimestamps } from "../utils/git-timestamps";

interface ContentModule {
  frontmatter?: {
    title?: string;
    description?: string;
    type?: string;
  };
}

interface ListArticleItem {
  title: string;
  description: string;
  href: string;
  type: string;
  createdAt: Date;
  createdLabel: string;
}

const sectionLabels = {
  blog: "Blog",
  note: "Note",
  project: "Project",
} as const;

export function getStaticPaths() {
  return ["blog", "note", "project"].map((section) => ({
    params: { section },
  }));
}

const { section } = Astro.params;

if (!section || !(section in sectionLabels)) {
  throw new Error("Unsupported section.");
}

const contentModules = import.meta.glob("../content/{blog,note,project}/*.{md,mdx}", {
  eager: true,
});

const listArticles = Object.entries(contentModules)
  .map(([path, mod]) => {
    const match = path.match(/^\.\.\/content\/(blog|note|project)\/([^/]+)\.(md|mdx)$/i);
    if (!match || match[1] !== section) return null;

    const frontmatter = (mod as ContentModule).frontmatter;
    const title = frontmatter?.title?.trim();
    const slug = match[2];
    const { createdAt, updatedAt } = getGitTimestamps(new URL(path, import.meta.url));
    const publishedAt = createdAt ?? updatedAt;

    if (!title || !publishedAt || Number.isNaN(publishedAt.getTime())) return null;

    return {
      title,
      description: frontmatter?.description?.trim() || "",
      href: `/${section}/${slug}/`,
      type: frontmatter?.type?.trim() || "Uncategorized",
      createdAt: publishedAt,
      createdLabel: new Intl.DateTimeFormat("en-US", {
        year: "numeric",
        month: "short",
        day: "2-digit",
      }).format(publishedAt),
    } satisfies ListArticleItem;
  })
  .filter((item): item is ListArticleItem => item !== null)
  .sort((a, b) => b.createdAt.getTime() - a.createdAt.getTime());

const groupedArticles = listArticles.reduce<Array<{ type: string; articles: ListArticleItem[] }>>((groups, article) => {
  const existingGroup = groups.find((group) => group.type === article.type);

  if (existingGroup) {
    existingGroup.articles.push(article);
    return groups;
  }

  groups.push({
    type: article.type,
    articles: [article],
  });
  return groups;
}, []);

const pageLabel = sectionLabels[section as keyof typeof sectionLabels];
---

<SectionListingPage pageLabel={pageLabel} groupedArticles={groupedArticles} />
