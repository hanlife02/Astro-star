---
import SectionListingPage from "../components/content/SectionListingPage.astro";
import { getArchiveSlugFromPath } from "../utils/content-slug";

interface ContentModule {
  frontmatter?: {
    archiveSlug?: string;
    type?: string;
  };
}

interface SectionCategoryEntry {
  archiveSlug: string;
  count: number;
  href: string;
  label: string;
}

const sectionLabels = {
  blog: "Blog",
  note: "Note",
  project: "Project",
} as const;

function normalizeArchiveSlug(value?: string) {
  const normalized = value?.trim().replace(/^\/+|\/+$/g, "") || "";
  return normalized && !normalized.includes("/") ? normalized : "";
}

function slugifyCategoryLabel(value: string) {
  return value
    .toLowerCase()
    .trim()
    .replace(/[`*_~()[\]{}]/g, "")
    .replace(/[^\p{Letter}\p{Number}\s-]/gu, "")
    .replace(/\s+/g, "-")
    .replace(/-+/g, "-")
    .replace(/^-|-$/g, "");
}

export function getStaticPaths() {
  return ["blog", "note", "project"].map((section) => ({
    params: { section },
  }));
}

const { section } = Astro.params;

if (!section || !(section in sectionLabels)) {
  throw new Error("Unsupported section.");
}

const contentModules = import.meta.glob("../content/{blog,note,project}/**/*.{md,mdx}", {
  eager: true,
});

const categories = Object.entries(contentModules)
  .map(([path, mod]) => {
    const match = path.match(/^\.\.\/content\/(blog|note|project)\/.+\.(md|mdx)$/i);
    if (!match || match[1] !== section) return null;

    const frontmatter = (mod as ContentModule).frontmatter;
    const directoryArchiveSlug = getArchiveSlugFromPath(path, section);
    const label = frontmatter?.type?.trim() || directoryArchiveSlug || "Uncategorized";
    const archiveSlug =
      (section === "blog" ? directoryArchiveSlug : "") ||
      normalizeArchiveSlug(frontmatter?.archiveSlug) ||
      directoryArchiveSlug ||
      slugifyCategoryLabel(label) ||
      "uncategorized";

    return {
      archiveSlug,
      label,
    };
  })
  .filter((item): item is { archiveSlug: string; label: string } => item !== null)
  .reduce<SectionCategoryEntry[]>((entries, item) => {
    const existingEntry = entries.find((entry) => entry.archiveSlug === item.archiveSlug);

    if (existingEntry) {
      existingEntry.count += 1;
      return entries;
    }

    entries.push({
      archiveSlug: item.archiveSlug,
      count: 1,
      href: `/${section}-archive/${item.archiveSlug}/`,
      label: item.label,
    });
    return entries;
  }, [])
  .sort((a, b) => a.label.localeCompare(b.label, "en-US"));

const pageLabel = sectionLabels[section as keyof typeof sectionLabels];
const viewAllHref = `/${section}-archive/`;
const viewAllLabel = `View all ${pageLabel.toLowerCase()}s`;
---

<SectionListingPage
  categories={categories}
  pageLabel={pageLabel}
  viewAllHref={viewAllHref}
  viewAllLabel={viewAllLabel}
/>
