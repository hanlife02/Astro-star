---
import HomeLayout from "../layouts/HomeLayout.astro";
import Signature from "../components/home/signature.astro";
import ArticleInfoCard from "../components/content/ArticleInfoCard.astro";
import FooterMeta from "../components/common/FooterMeta.astro";
import { getGitTimestamps } from "../utils/git-timestamps";
import "../style/pages/content-page.css";

interface ContentModule {
  frontmatter?: {
    title?: string;
    description?: string;
    type?: string;
  };
}

interface ListArticleItem {
  title: string;
  description: string;
  href: string;
  type: string;
  createdAt: Date;
  createdLabel: string;
}

const sectionLabels = {
  blog: "Blog",
  note: "Note",
  project: "Project",
} as const;

export function getStaticPaths() {
  return ["blog", "note", "project"].map((section) => ({
    params: { section },
  }));
}

const { section } = Astro.params;

if (!section || !(section in sectionLabels)) {
  throw new Error("Unsupported section.");
}

const contentModules = import.meta.glob("../content/{blog,note,project}/*.{md,mdx}", {
  eager: true,
});

const listArticles = Object.entries(contentModules)
  .map(([path, mod]) => {
    const match = path.match(/^\.\.\/content\/(blog|note|project)\/([^/]+)\.(md|mdx)$/i);
    if (!match || match[1] !== section) return null;

    const frontmatter = (mod as ContentModule).frontmatter;
    const title = frontmatter?.title?.trim();
    const slug = match[2];
    const { createdAt, updatedAt } = getGitTimestamps(new URL(path, import.meta.url));
    const publishedAt = createdAt ?? updatedAt;

    if (!title || !publishedAt || Number.isNaN(publishedAt.getTime())) return null;

    return {
      title,
      description: frontmatter?.description?.trim() || "",
      href: `/${section}/${slug}/`,
      type: frontmatter?.type?.trim() || "Uncategorized",
      createdAt: publishedAt,
      createdLabel: new Intl.DateTimeFormat("en-US", {
        year: "numeric",
        month: "short",
        day: "2-digit",
      }).format(publishedAt),
    } satisfies ListArticleItem;
  })
  .filter((item): item is ListArticleItem => item !== null)
  .sort((a, b) => b.createdAt.getTime() - a.createdAt.getTime());

const groupedArticles = listArticles.reduce<Array<{ type: string; articles: ListArticleItem[] }>>((groups, article) => {
  const existingGroup = groups.find((group) => group.type === article.type);

  if (existingGroup) {
    existingGroup.articles.push(article);
    return groups;
  }

  groups.push({
    type: article.type,
    articles: [article],
  });
  return groups;
}, []);

const pageLabel = sectionLabels[section as keyof typeof sectionLabels];
const toAnchorId = (value: string) => value.toLowerCase().trim().replace(/\s+/g, "-");
---

<HomeLayout mainCol2Fr="4fr" mainCol3Fr="1.5fr">
  <Signature slot="signature" />

  <section slot="profile" class="content-page content-page--listing" aria-label={`${pageLabel} listing content`}>
    <div class="content-page-body">
      <header class="listing-header">
        <h1 class="listing-header-title">{pageLabel}</h1>
      </header>

      {
        groupedArticles.length > 0 ? (
          <div class="listing-groups">
            {groupedArticles.map((group) => (
              <section class="listing-group" aria-label={`${group.type} articles`}>
                <h2 id={toAnchorId(group.type)} class="listing-group-title">{group.type}</h2>
                <div class="listing-group-items">
                  {group.articles.map((article) => (
                    <ArticleInfoCard
                      title={article.title}
                      href={article.href}
                      createdLabel={article.createdLabel}
                      description={article.description}
                    />
                  ))}
                </div>
              </section>
            ))}
          </div>
        ) : (
          <p class="content-toc-empty">No content yet.</p>
        )
      }
    </div>
  </section>

  <aside slot="latest" class="content-toc" aria-label={`${pageLabel} categories`}>
    {
      groupedArticles.length > 0 ? (
        <ol class="content-toc-list">
          {groupedArticles.map((group) => (
            <li class="content-toc-item content-toc-item--depth-2">
              <a class="content-toc-link content-toc-link--depth-2" href={`#${toAnchorId(group.type)}`}>
                {group.type}
              </a>
            </li>
          ))}
        </ol>
      ) : (
        <p class="content-toc-empty">No categories yet.</p>
      )
    }
  </aside>

  <FooterMeta slot="footer-info" />
</HomeLayout>
