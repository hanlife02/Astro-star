---
import BaseLayout from "./BaseLayout.astro";
import { site } from "../config/site";
import "../style/layouts/content-layout.css";

interface NavItem {
  label: string;
  href: string;
}

interface Props {
  title?: string;
}

const { title } = Astro.props as Props;
const pathname = Astro.url.pathname.replace(/\/+$/, "") || "/";
const navItems: readonly NavItem[] = [{ label: "Home", href: "/" }, ...site.nav];
---

<BaseLayout title={title}>
  <slot name="background" slot="background" />

  <main class="content-shell">
    <header class="content-shell-header" aria-label="Content page header">
      <a class="content-shell-brand" href="/">{site.name}</a>

      <nav class="content-shell-nav" aria-label="Primary navigation">
        <ul class="content-shell-nav-list">
          {
            navItems.map((item) => {
              const isCurrent =
                item.href === "/"
                  ? pathname === "/"
                  : pathname === item.href.replace(/\/+$/, "");

              return (
                <li>
                  <a
                    class:list={["content-shell-nav-link", isCurrent && "is-current"]}
                    href={item.href}
                    aria-current={isCurrent ? "page" : undefined}
                  >
                    {item.label}
                  </a>
                </li>
              );
            })
          }
        </ul>
      </nav>

      <slot name="header" />
    </header>

    <div class="content-shell-body">
      <section class="content-shell-main" aria-label="Main content">
        <slot />
      </section>

      <aside class="content-shell-aside" aria-label="Supplementary content">
        <slot name="aside" />
      </aside>
    </div>

    <footer class="content-shell-footer" aria-label="Content page footer">
      <div class="content-shell-footer-info">
        <slot name="footer-info" />
      </div>

      <nav class="content-shell-footer-nav" aria-label="Footer navigation">
        <slot name="footer-icons" />
      </nav>
    </footer>
  </main>

  <slot name="body-end" slot="body-end" />
</BaseLayout>
