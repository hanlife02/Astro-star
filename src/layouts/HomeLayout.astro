---
import BaseLayout from "./BaseLayout.astro";
import HomeShellBackground from "../components/layout/HomeShellBackground.astro";
import HomeShellFrame from "../components/layout/HomeShellFrame.astro";
import HomeShellScripts from "../components/layout/HomeShellScripts.astro";
import "../style/base/tokens.css";
import "../style/layouts/home-layout.css";
import "../style/pages/content-page.css";
import { site } from "../config/site";

interface Props {
  mainCol2Fr?: string;
  mainCol3Fr?: string;
  variant?: "default" | "article";
  background?: "home" | "code-rain" | "constellation";
}

const THEME_COOKIE_KEY = "theme-preference";
const VALID_THEME_MODES = ["light", "dark", "system"] as const;

type ThemeMode = (typeof VALID_THEME_MODES)[number];

const { mainCol2Fr, mainCol3Fr, variant, background } = Astro.props as Props;
const pathname = Astro.url.pathname.replace(/\/+$/, "") || "/";
const pathSegments = pathname.split("/").filter(Boolean);
const shellVariant = variant ?? (pathSegments.length > 1 ? "article" : "default");
const backgroundVariant =
  background ?? (pathname === "/about" ? "code-rain" : pathname === "/links" ? "constellation" : "home");
const foldedNavItems = site.site.nav;
const githubUsername = site.profile.githubUsername.trim();
const githubHref = githubUsername
  ? `https://github.com/${encodeURIComponent(githubUsername)}`
  : "";
const shellStyle = [
  mainCol2Fr ? `--main-col-2-fr: ${mainCol2Fr}` : "",
  mainCol3Fr ? `--main-col-3-fr: ${mainCol3Fr}` : "",
]
  .filter(Boolean)
  .join("; ");
const themeModeCookie = Astro.cookies.get(THEME_COOKIE_KEY)?.value;
const initialThemeMode: ThemeMode =
  themeModeCookie === "light" || themeModeCookie === "dark" || themeModeCookie === "system"
    ? themeModeCookie
    : "system";
---

<BaseLayout>
  <slot name="head" slot="head" />
  <HomeShellBackground slot="background" pathname={pathname} background={backgroundVariant} />
  <HomeShellFrame
    foldedNavItems={foldedNavItems}
    githubHref={githubHref}
    initialThemeMode={initialThemeMode}
    shellStyle={shellStyle}
    shellVariant={shellVariant}
  >
    <slot name="signature" slot="signature" />
    <slot name="side-nav" slot="side-nav" />
    <slot name="profile" slot="profile" />
    <slot name="latest" slot="latest" />
    <slot name="footer-info" slot="footer-info" />
    <slot name="footer-icons" slot="footer-icons" />
  </HomeShellFrame>
  <HomeShellScripts slot="body-end" />
</BaseLayout>
