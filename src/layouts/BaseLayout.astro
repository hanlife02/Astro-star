---
import { site } from "../config/site";

interface Props {
  title?: string;
}

const THEME_COOKIE_KEY = "theme-preference";
const RESOLVED_THEME_COOKIE_KEY = "theme-resolved";
const VALID_THEME_MODES = ["light", "dark", "system"] as const;

type ThemeMode = (typeof VALID_THEME_MODES)[number];

const isThemeMode = (value: string | undefined): value is ThemeMode =>
  VALID_THEME_MODES.includes(value as ThemeMode);

const { title } = Astro.props as Props;
const pathname = Astro.url.pathname.replace(/\/+$/, "") || "/";
const routeRoot = pathname.split("/").filter(Boolean)[0] || "";
const documentLang = ["blog", "note", "project", "blog-archive", "note-archive", "project-archive"].includes(routeRoot)
  ? "zh-CN"
  : "en";
const pageName =
  pathname === "/"
    ? "Home"
    : pathname
        .split("/")
        .filter(Boolean)
        .map((segment) => segment.charAt(0).toUpperCase() + segment.slice(1))
        .join(" / ");
const pageTitle = title ?? `${pageName} - ${site.name}`;
const themeModeCookie = Astro.cookies.get(THEME_COOKIE_KEY)?.value;
const resolvedThemeCookie = Astro.cookies.get(RESOLVED_THEME_COOKIE_KEY)?.value;
const initialThemeMode: ThemeMode = isThemeMode(themeModeCookie) ? themeModeCookie : "system";
const initialTheme =
  initialThemeMode === "light" || initialThemeMode === "dark"
    ? initialThemeMode
    : resolvedThemeCookie === "dark"
      ? "dark"
      : "light";
---

<html lang={documentLang} data-theme={initialTheme} data-theme-mode={initialThemeMode}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="color-scheme"
      content={initialTheme === "dark" ? "dark light" : "light dark"}
    />
    <meta
      name="theme-color"
      content={initialTheme === "dark" ? "#000000" : "#ffffff"}
    />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={site.iconSrc} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${site.name} RSS Feed`}
      href={new URL("/rss.xml", site.url).toString()}
    />
    <title>{pageTitle}</title>
    <script is:inline>
      (function() {
        var root = document.documentElement;
        var storageKey = 'theme-preference';
        var resolvedCookieKey = 'theme-resolved';
        var prefersDark = matchMedia('(prefers-color-scheme: dark)');
        var readCookie = function(key) {
          var match = document.cookie.match(new RegExp('(?:^|; )' + key.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + '=([^;]*)'));
          return match ? decodeURIComponent(match[1]) : '';
        };
        var writeCookie = function(key, value) {
          document.cookie = key + '=' + encodeURIComponent(value) + '; Max-Age=31536000; Path=/; SameSite=Lax';
        };
        var readStorage = function() {
          try {
            return localStorage.getItem(storageKey) || '';
          } catch (error) {
            return '';
          }
        };
        var writeStorage = function(value) {
          try {
            localStorage.setItem(storageKey, value);
          } catch (error) {}
        };
        var isValidMode = function(value) {
          return value === 'light' || value === 'dark' || value === 'system';
        };
        var storedMode = readStorage();
        var cookieMode = readCookie(storageKey);
        var mode = isValidMode(storedMode)
          ? storedMode
          : isValidMode(cookieMode)
            ? cookieMode
            : isValidMode(root.dataset.themeMode)
              ? root.dataset.themeMode
              : 'system';
        var resolved = mode === 'system' ? (prefersDark.matches ? 'dark' : 'light') : mode;
        root.dataset.themeMode = mode;
        root.dataset.theme = resolved;
        root.style.colorScheme = resolved;
        root.style.backgroundColor = resolved === 'dark' ? '#000000' : '#ffffff';
        writeStorage(mode);
        writeCookie(storageKey, mode);
        writeCookie(resolvedCookieKey, resolved);
      })();
    </script>
    <slot name="head" />
  </head>
  <body>
    <slot name="background" />
    <slot />
    <slot name="body-end" />
  </body>
</html>
