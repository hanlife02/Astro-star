---
import { site } from "../config/site";

interface Props {
  title?: string;
}

const { title } = Astro.props as Props;
const pathname = Astro.url.pathname.replace(/\/+$/, "") || "/";
const routeRoot = pathname.split("/").filter(Boolean)[0] || "";
const documentLang = ["blog", "note", "project", "blog-archive", "note-archive", "project-archive"].includes(routeRoot)
  ? "zh-CN"
  : "en";
const pageName =
  pathname === "/"
    ? "Home"
    : pathname
        .split("/")
        .filter(Boolean)
        .map((segment) => segment.charAt(0).toUpperCase() + segment.slice(1))
        .join(" / ");
const pageTitle = title ?? `${pageName} - ${site.name}`;
---

<html lang={documentLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={site.iconSrc} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${site.name} RSS Feed`}
      href={new URL("/rss.xml", site.url).toString()}
    />
    <title>{pageTitle}</title>
    <script is:inline>
      (function() {
        var t = localStorage.getItem('theme-preference');
        var m = t === 'light' || t === 'dark' ? t
              : (t === 'system' || !t)
              ? (matchMedia('(prefers-color-scheme:dark)').matches ? 'dark' : 'light')
              : 'light';
        document.documentElement.dataset.theme = m;
        document.documentElement.dataset.themeMode = t || 'system';
      })();
    </script>
    <slot name="head" />
  </head>
  <body>
    <slot name="background" />
    <slot />
    <slot name="body-end" />
  </body>
</html>
