---
import { ClientRouter } from "astro:transitions";
import { site } from "../config/site";
import { getEnabledSocialLinks, getSocialLink } from "../utils/social";
import katexStylesheetUrl from "katex/dist/katex.min.css?url";
import "../style/base/route-transitions.css";

interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string;
  imageUrl?: string;
  ogTitle?: string;
  ogType?: "article" | "website";
  twitterCard?: "summary" | "summary_large_image";
  includeKatexStyles?: boolean;
}

const VALID_THEME_MODES = ["light", "dark", "system"] as const;

type ThemeMode = (typeof VALID_THEME_MODES)[number];

const {
  title,
  description,
  canonicalUrl,
  imageUrl,
  ogTitle,
  ogType,
  twitterCard,
  includeKatexStyles = false,
} = Astro.props as Props;
const pageDescription = description ?? site.site.description;
const pathname = Astro.url.pathname.replace(/\/+$/, "") || "/";
const routeRoot = pathname.split("/").filter(Boolean)[0] || "";
const PAGE_NAME_BY_ROUTE_ROOT = {
  "": "Home",
  about: "About",
  blog: "Blog",
  "blog-archive": "Blog",
  note: "Note",
  "note-archive": "Note",
  project: "Project",
  links: "Links",
} as const;
const documentLang = [
  "blog",
  "note",
  "project",
  "blog-archive",
  "note-archive",
].includes(routeRoot)
  ? "zh-CN"
  : "en";
const pageName =
  PAGE_NAME_BY_ROUTE_ROOT[routeRoot as keyof typeof PAGE_NAME_BY_ROUTE_ROOT] ??
  (routeRoot ? routeRoot.charAt(0).toUpperCase() + routeRoot.slice(1) : "Home");
const pageTitle = title ?? `${pageName} - ${site.site.name}`;
const canonicalHref = new URL(
  canonicalUrl?.trim() || Astro.url.pathname,
  site.site.url,
).toString();
const socialTitle = ogTitle ?? pageTitle;
const socialImageUrl = new URL(
  imageUrl?.trim() || site.site.iconSrc,
  site.site.url,
).toString();
const faviconSrc = site.site.iconSrc.trim() || "/site-icon.svg";
const faviconHref = faviconSrc.includes("?")
  ? faviconSrc
  : `${faviconSrc}?v=20260521`;
const openGraphType = ogType ?? "website";
const openGraphLocale = "zh_CN";
const twitterCardType = twitterCard ?? "summary_large_image";
const initialThemeMode: ThemeMode = "system";
const initialTheme = "light";
const siteUrl = new URL("/", site.site.url).toString();
const personId = `${siteUrl}#person`;
const websiteId = `${siteUrl}#website`;
const profileEmail = getSocialLink("mail")?.handle?.trim() ?? "";
const sameAs = getEnabledSocialLinks()
  .map((item) => item.href)
  .filter((href) => /^https?:\/\//.test(href));
const siteJsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": websiteId,
      url: siteUrl,
      name: site.site.name,
      description: site.site.description,
      inLanguage: documentLang,
      publisher: {
        "@id": personId,
      },
    },
    {
      "@type": "Person",
      "@id": personId,
      name: site.profile.name,
      url: siteUrl,
      image: new URL(site.profile.avatarSrc, site.site.url).toString(),
      email: profileEmail || undefined,
      sameAs: sameAs.length > 0 ? sameAs : undefined,
    },
  ],
};
const siteJsonLdText = JSON.stringify(siteJsonLd).replace(/</g, "\\u003c");
---

<html
  lang={documentLang}
  data-theme={initialTheme}
  data-theme-mode={initialThemeMode}
>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      document.documentElement.dataset.js = "true";
    </script>
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#ffffff" />
    <meta name="description" content={pageDescription} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalHref} />
    <meta property="og:locale" content={openGraphLocale} />
    <meta property="og:site_name" content={site.site.name} />
    <meta property="og:title" content={socialTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content={openGraphType} />
    <meta property="og:url" content={canonicalHref} />
    <meta property="og:image" content={socialImageUrl} />
    <meta name="twitter:card" content={twitterCardType} />
    <meta name="twitter:title" content={socialTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={socialImageUrl} />
    <ClientRouter fallback="animate" />
    {includeKatexStyles && <link rel="stylesheet" href={katexStylesheetUrl} />}
    <link
      rel="preload"
      href="/fonts/Biotif-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/Biotif-SemiBold.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="icon" type="image/svg+xml" sizes="any" href={faviconHref} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${site.site.name} RSS Feed`}
      href={new URL("/rss.xml", site.site.url).toString()}
    />
    <title>{pageTitle}</title>
    <script is:inline type="application/ld+json" set:html={siteJsonLdText} />
    <script is:inline>
      (function () {
        var root = document.documentElement;
        var storageKey = "theme-preference";
        var resolvedCookieKey = "theme-resolved";
        var prefersDark = matchMedia("(prefers-color-scheme: dark)");
        var readCookie = function (key) {
          var match = document.cookie.match(
            new RegExp(
              "(?:^|; )" +
                key.replace(/[.*+?^${}()|[\]\\]/g, "\\$&") +
                "=([^;]*)",
            ),
          );
          return match ? decodeURIComponent(match[1]) : "";
        };
        var writeCookie = function (key, value) {
          document.cookie =
            key +
            "=" +
            encodeURIComponent(value) +
            "; Max-Age=31536000; Path=/; SameSite=Lax";
        };
        var readStorage = function () {
          try {
            return localStorage.getItem(storageKey) || "";
          } catch (error) {
            return "";
          }
        };
        var writeStorage = function (value) {
          try {
            localStorage.setItem(storageKey, value);
          } catch (error) {}
        };
        var isValidMode = function (value) {
          return value === "light" || value === "dark" || value === "system";
        };
        var storedMode = readStorage();
        var cookieMode = readCookie(storageKey);
        var mode = isValidMode(storedMode)
          ? storedMode
          : isValidMode(cookieMode)
            ? cookieMode
            : isValidMode(root.dataset.themeMode)
              ? root.dataset.themeMode
              : "system";
        var resolved =
          mode === "system" ? (prefersDark.matches ? "dark" : "light") : mode;
        root.dataset.themeMode = mode;
        root.dataset.theme = resolved;
        root.style.colorScheme = resolved;
        root.style.backgroundColor =
          resolved === "dark" ? "#000000" : "#ffffff";
        writeStorage(mode);
        writeCookie(storageKey, mode);
        writeCookie(resolvedCookieKey, resolved);
      })();
    </script>
    <slot name="head" />
  </head>
  <body>
    <slot name="background" />
    <slot />
    <slot name="body-end" />
  </body>
</html>
