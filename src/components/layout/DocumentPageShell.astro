---
import ContentShell from "./ContentShell.astro";
import TocPanel from "../content/TocPanel.astro";

interface TocItem {
  href: string;
  label: string;
  depth?: 1 | 2 | 3;
}

interface Props {
  variant?: "default" | "article";
  background?: "home" | "code-rain" | "constellation";
  title?: string;
  description?: string;
  canonicalUrl?: string;
  imageUrl?: string;
  ogTitle?: string;
  ogType?: "article" | "website";
  twitterCard?: "summary" | "summary_large_image";
  includeKatexStyles?: boolean;
  contentClass?: string;
  contentAriaLabel: string;
  tocAriaLabel: string;
  tocTitle?: string;
  tocEmptyText?: string;
  tocItems: TocItem[];
}

const {
  variant = "default",
  background,
  title,
  description,
  canonicalUrl,
  imageUrl,
  ogTitle,
  ogType,
  twitterCard,
  includeKatexStyles,
  contentClass = "content-page",
  contentAriaLabel,
  tocAriaLabel,
  tocTitle,
  tocEmptyText,
  tocItems,
} = Astro.props as Props;
---

<ContentShell
  variant={variant}
  background={background}
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  imageUrl={imageUrl}
  ogTitle={ogTitle}
  ogType={ogType}
  twitterCard={twitterCard}
  includeKatexStyles={includeKatexStyles}
  contentClass={contentClass}
  contentAriaLabel={contentAriaLabel}
  tocAriaLabel={tocAriaLabel}
>
  <slot name="head" slot="head" />
  <slot />

  <TocPanel
    slot="toc"
    title={tocTitle}
    emptyText={tocEmptyText}
    items={tocItems}
  />
</ContentShell>
