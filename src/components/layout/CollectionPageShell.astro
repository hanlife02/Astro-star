---
import TocPanel from "../content/TocPanel.astro";
import ContentShell from "./ContentShell.astro";

interface TocItem {
  href: string;
  label: string;
  depth?: 1 | 2 | 3;
}

interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string;
  imageUrl?: string;
  ogTitle?: string;
  ogType?: "article" | "website";
  twitterCard?: "summary" | "summary_large_image";
  contentClass?: string;
  tocClass?: string;
  contentAriaLabel: string;
  tocAriaLabel: string;
  tocItems: TocItem[];
  tocEmptyText?: string;
}

const {
  title,
  description,
  canonicalUrl,
  imageUrl,
  ogTitle,
  ogType,
  twitterCard,
  contentClass = "content-page content-page--collection content-page--listing",
  tocClass = "content-toc",
  contentAriaLabel,
  tocAriaLabel,
  tocItems,
  tocEmptyText,
} = Astro.props as Props;
---

<ContentShell
  variant="default"
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  imageUrl={imageUrl}
  ogTitle={ogTitle}
  ogType={ogType}
  twitterCard={twitterCard}
  contentClass={contentClass}
  tocClass={tocClass}
  contentAriaLabel={contentAriaLabel}
  tocAriaLabel={tocAriaLabel}
>
  <slot />

  <TocPanel slot="toc" items={tocItems} emptyText={tocEmptyText} />
</ContentShell>
