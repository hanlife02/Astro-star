---
import HomeBackground from "../background/HomeBackground.astro";
import ConstellationBackground from "../background/ConstellationBackground.astro";
import CodeRainBackground from "../background/CodeRainBackground.astro";
import { site } from "../../config/site";

interface Props {
  pathname: string;
  background?: "home" | "code-rain" | "constellation";
}

const { pathname, background } = Astro.props as Props;
const resolvedBackground =
  background ?? (pathname === "/about" ? "code-rain" : pathname === "/links" ? "constellation" : "home");
---

{
  resolvedBackground === "code-rain" ? (
    <CodeRainBackground slot="background" keywords={site.site.codeRainKeywords} />
  ) : resolvedBackground === "constellation" ? (
    <ConstellationBackground slot="background" />
  ) : (
    <HomeBackground slot="background" mode="light" />
  )
}
