---
interface TocItem {
  href: string;
  label: string;
  depth?: 1 | 2 | 3;
}

interface Props {
  items: TocItem[];
  title?: string;
  emptyText?: string;
}

const { items, title, emptyText = "The author is too lazy to write a title." } = Astro.props as Props;

const hasHanCharacters = /[\u3400-\u9fff\uf900-\ufaff]/u;
const hasLatinCharacters = /[A-Za-z]/;

function getTocItemLang(label: string) {
  return hasLatinCharacters.test(label) && !hasHanCharacters.test(label) ? "en" : undefined;
}
---

{
  items.length > 0 ? (
    <>
      {title && <p class="content-toc-title">{title}</p>}
      <ol class="content-toc-list">
        {items.map((item) => (
          <li
            class:list={[
              "content-toc-item",
              `content-toc-item--depth-${item.depth ?? 2}`,
            ]}
          >
            <a
              class={`content-toc-link content-toc-link--depth-${item.depth ?? 2}`}
              href={item.href}
              lang={getTocItemLang(item.label)}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ol>
    </>
  ) : (
    <p class="content-toc-empty">{emptyText}</p>
  )
}
