---
import "@waline/client/waline.css";

interface Props {
  articleRoutePath?: string;
  walineServerURL?: string;
}

const { articleRoutePath: rawArticleRoutePath, walineServerURL = "" } =
  Astro.props as Props;

const normalizeWalinePath = (pathname: string) => {
  const trimmedPathname = pathname.trim();

  if (!trimmedPathname || trimmedPathname === "/") {
    return "/";
  }

  return `/${trimmedPathname.replace(/^\/+|\/+$/g, "")}/`;
};

const articleRoutePath = normalizeWalinePath(
  rawArticleRoutePath || Astro.url.pathname,
);
---

<section
  class="article-comments"
  aria-label="Comments"
  data-article-waline
  data-waline-server-url={walineServerURL || undefined}
  data-waline-path={articleRoutePath}
>
  <div class="article-comments-thread" data-waline-thread></div>
</section>
