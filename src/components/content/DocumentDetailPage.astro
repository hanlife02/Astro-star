---
import DocumentPageShell from "../layout/DocumentPageShell.astro";

interface TocHeading {
  depth: 1 | 2 | 3 | 4 | 5 | 6;
  slug: string;
  text: string;
}

interface Props {
  backAriaLabel?: string;
  backHref?: string;
  backLabel?: string;
  variant?: "default" | "article";
  background?: "home" | "code-rain" | "constellation" | "content";
  title?: string;
  contentTitle?: string;
  contentTitleId?: string;
  contentDescription?: string;
  description?: string;
  canonicalUrl?: string;
  imageUrl?: string;
  ogTitle?: string;
  ogType?: "article" | "website";
  twitterCard?: "summary" | "summary_large_image";
  includeKatexStyles?: boolean;
  contentClass?: string;
  contentAriaLabel: string;
  tocAriaLabel: string;
  tocTitle?: string;
  tocHeadings: TocHeading[];
  DocumentContent: any;
  enableDocumentNavigation?: boolean;
}

const {
  backAriaLabel,
  backHref,
  backLabel,
  variant = "article",
  background = "content",
  title,
  contentTitle,
  contentTitleId,
  contentDescription,
  description,
  canonicalUrl,
  imageUrl,
  ogTitle,
  ogType = "website",
  twitterCard,
  includeKatexStyles,
  contentClass = "content-page content-page--article",
  contentAriaLabel,
  tocAriaLabel,
  tocTitle,
  tocHeadings,
  DocumentContent,
  enableDocumentNavigation = true,
} = Astro.props as Props;
---

<DocumentPageShell
  backAriaLabel={backAriaLabel}
  backHref={backHref}
  backLabel={backLabel}
  variant={variant}
  background={background}
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  imageUrl={imageUrl}
  ogTitle={ogTitle}
  ogType={ogType}
  twitterCard={twitterCard}
  includeKatexStyles={includeKatexStyles}
  contentClass={contentClass}
  contentAriaLabel={contentAriaLabel}
  tocAriaLabel={tocAriaLabel}
  tocTitle={tocTitle}
  enableDocumentNavigation={enableDocumentNavigation}
  tocItems={tocHeadings.map((heading) => ({
    href: `#${heading.slug}`,
    label: heading.text,
    depth: heading.depth,
  }))}
>
  <slot name="head" slot="head" />
  <slot name="before-content" />
  {
    (contentTitle || contentDescription) && (
      <header class="content-page-header">
        {contentTitle && (
          <h1 id={contentTitleId} class="content-page-title">
            {contentTitle}
          </h1>
        )}
        {contentDescription && (
          <p class="content-page-description">{contentDescription}</p>
        )}
      </header>
    )
  }
  <DocumentContent />
  <slot name="after-content" />
</DocumentPageShell>
