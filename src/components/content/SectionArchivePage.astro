---
import ContentShell from "../layout/ContentShell.astro";
import "../../style/pages/content-page.css";
import "../../style/components/content/section-archive-page.css";

interface ArchiveArticleItem {
  createdLabel: string;
  href: string;
  title: string;
  year: string;
}

interface ArchiveYearGroup {
  articles: ArchiveArticleItem[];
  year: string;
}

interface Props {
  pageLabel: string;
  yearGroups: ArchiveYearGroup[];
}

const { pageLabel, yearGroups } = Astro.props as Props;
---

<ContentShell
  variant="default"
  contentClass="content-page content-page--listing"
  contentAriaLabel={`${pageLabel} archive content`}
  tocAriaLabel={`${pageLabel} archive navigation`}
>
      <header class="listing-header">
        <h1 class="listing-header-title">{pageLabel}</h1>
      </header>

      {
        yearGroups.length > 0 ? (
          <div class="archive-groups">
            {yearGroups.map((group) => (
              <section class="archive-group" aria-label={`${group.year} archive`}>
                <h2 id={group.year} class="archive-year-heading">{group.year}</h2>
                <ol class="archive-list" aria-label={`${group.year} timeline`}>
                  {group.articles.map((article) => (
                    <li class="archive-list-item">
                      <time class="archive-item-date">{article.createdLabel}</time>
                      <a class="archive-item-link" href={article.href}>{article.title}</a>
                    </li>
                  ))}
                </ol>
              </section>
            ))}
          </div>
        ) : (
          <p class="content-toc-empty">No content yet.</p>
        )
      }

  <Fragment slot="toc">
    {
      yearGroups.length > 0 ? (
        <ol class="content-toc-list">
          {yearGroups.map((group) => (
            <li class="content-toc-item content-toc-item--depth-2">
              <a class="content-toc-link content-toc-link--depth-2" href={`#${group.year}`}>
                {group.year}
              </a>
            </li>
          ))}
        </ol>
      ) : (
        <p class="content-toc-empty">No archive yet.</p>
      )
    }
  </Fragment>
</ContentShell>
