---
import CollectionPageShell from "../layout/CollectionPageShell.astro";

interface ArchiveArticleItem {
  createdLabel: string;
  href: string;
  title: string;
  year: string;
}

interface ArchiveYearGroup {
  articles: ArchiveArticleItem[];
  year: string;
}

interface Props {
  pageLabel: string;
  yearGroups: ArchiveYearGroup[];
}

const { pageLabel, yearGroups } = Astro.props as Props;
---

<CollectionPageShell
  contentAriaLabel={`${pageLabel} archive content`}
  tocAriaLabel={`${pageLabel} archive navigation`}
  tocEmptyText="No archive yet."
  tocItems={yearGroups.map((group) => ({
    href: `#${group.year}`,
    label: group.year,
    depth: 2 as const,
  }))}
>
      <header class="listing-header collection-page-header">
        <h1 class="listing-header-title collection-page-title">{pageLabel}</h1>
      </header>

      {
        yearGroups.length > 0 ? (
          <div class="archive-groups collection-archive-groups">
            {yearGroups.map((group) => (
              <section class="archive-group collection-archive-group" aria-label={`${group.year} archive`}>
                <h2 id={group.year} class="archive-year-heading collection-archive-year">{group.year}</h2>
                <ol class="archive-list collection-archive-list" aria-label={`${group.year} timeline`}>
                  {group.articles.map((article) => (
                    <li class="archive-list-item collection-archive-item">
                      <time class="archive-item-date collection-archive-date">{article.createdLabel}</time>
                      <a class="archive-item-link collection-archive-link" href={article.href}>{article.title}</a>
                    </li>
                  ))}
                </ol>
              </section>
            ))}
          </div>
        ) : (
          <p class="content-toc-empty">No content yet.</p>
        )
      }
</CollectionPageShell>
