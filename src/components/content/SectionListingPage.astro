---
import CollectionPageShell from "../layout/CollectionPageShell.astro";

interface SectionCategoryEntry {
  archiveSlug: string;
  articles: {
    createdLabel: string;
    href: string;
    title: string;
  }[];
  count: number;
  href?: string;
  label: string;
}

interface Props {
  categories: SectionCategoryEntry[];
  pageLabel: string;
  showCounts?: boolean;
  viewAllHref?: string;
  viewAllLabel?: string;
}

const {
  categories,
  pageLabel,
  showCounts = true,
  viewAllHref,
  viewAllLabel,
} = Astro.props as Props;

const toAnchorId = (value: string) =>
  value.toLowerCase().trim().replace(/\s+/g, "-");
---

<CollectionPageShell
  tocClass="content-toc content-toc--collection content-toc--listing"
  contentAriaLabel={`${pageLabel} listing content`}
  tocAriaLabel={`${pageLabel} categories`}
  tocEmptyText="No categories yet."
  tocItems={categories.map((category) => ({
    href: `#${toAnchorId(category.label)}`,
    label: category.label,
    depth: 2 as const,
  }))}
>
  <header class="listing-header collection-page-header">
    <div class="listing-header-bar collection-page-header-bar">
      <h1
        class="listing-header-title listing-header-title--compact collection-page-title collection-page-title--compact"
      >
        {pageLabel}
      </h1>
      {
        viewAllHref && viewAllLabel && (
          <a
            class="listing-view-all-link collection-page-view-all-link"
            href={viewAllHref}
          >
            <span class="listing-view-all-link-text collection-page-view-all-link-text">
              {viewAllLabel}
            </span>
            <span
              class="listing-view-all-link-arrow collection-page-view-all-link-arrow"
              aria-hidden="true"
            />
          </a>
        )
      }
    </div>
  </header>

  {
    categories.length > 0 ? (
      <div class="archive-groups collection-archive-groups">
        {categories.map((category) => (
          <section
            class="archive-group collection-archive-group"
            aria-label={`${category.label} category`}
          >
            <h2
              id={toAnchorId(category.label)}
              class="archive-year-heading collection-archive-year"
            >
              {category.href ? (
                <a
                  class="listing-category-heading-link collection-page-category-heading-link"
                  href={category.href}
                  aria-label={`View more ${category.label}`}
                  title={`View more ${category.label}`}
                >
                  <span class="listing-category-heading-text collection-page-category-heading-text">
                    {category.label}
                    {showCounts && (
                      <span class="listing-category-count collection-page-category-count">{` (${category.count})`}</span>
                    )}
                  </span>
                  <span class="listing-category-heading-hint collection-page-category-heading-hint">
                    View more
                  </span>
                </a>
              ) : (
                <span class="listing-category-heading-text collection-page-category-heading-text">
                  {category.label}
                  {showCounts && (
                    <span class="listing-category-count collection-page-category-count">{` (${category.count})`}</span>
                  )}
                </span>
              )}
            </h2>
            <ol
              class="archive-list collection-archive-list"
              aria-label={`${category.label} articles`}
            >
              {category.articles.map((article) => (
                <li class="archive-list-item collection-archive-item">
                  <time class="archive-item-date collection-archive-date">
                    {article.createdLabel}
                  </time>
                  <a
                    class="archive-item-link collection-archive-link"
                    href={article.href}
                  >
                    <span class="archive-item-link-text collection-archive-link-text">
                      {article.title}
                    </span>
                    <span
                      class="archive-item-link-arrow collection-archive-link-arrow"
                      aria-hidden="true"
                    />
                  </a>
                </li>
              ))}
            </ol>
          </section>
        ))}
      </div>
    ) : (
      <p class="content-toc-empty">No content yet.</p>
    )
  }
</CollectionPageShell>
