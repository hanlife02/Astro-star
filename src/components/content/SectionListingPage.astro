---
import ContentShell from "../layout/ContentShell.astro";
import "../../style/pages/content-page.css";
import "../../style/components/content/section-listing-page.css";

interface SectionCategoryEntry {
  archiveSlug: string;
  count: number;
  href: string;
  label: string;
}

interface Props {
  categories: SectionCategoryEntry[];
  pageLabel: string;
  viewAllHref: string;
  viewAllLabel: string;
}

const { categories, pageLabel, viewAllHref, viewAllLabel } = Astro.props as Props;

const toAnchorId = (value: string) => value.toLowerCase().trim().replace(/\s+/g, "-");
---

<ContentShell
  variant="default"
  contentClass="content-page content-page--listing"
  tocClass="content-toc content-toc--listing"
  contentAriaLabel={`${pageLabel} listing content`}
  tocAriaLabel={`${pageLabel} categories`}
>
      <header class="listing-header">
        <div class="listing-header-bar">
          <h1 class="listing-header-title listing-header-title--compact">{pageLabel}</h1>
          <a class="listing-view-all-link" href={viewAllHref}>
            <span>{viewAllLabel}</span>
            <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
      </header>

      {
        categories.length > 0 ? (
          <div class="listing-groups">
            <ol class="content-toc-list" aria-label={`${pageLabel} categories`}>
              {categories.map((category) => (
                <li id={toAnchorId(category.label)} class="content-toc-item content-toc-item--depth-2">
                  <a class="content-toc-link content-toc-link--depth-2" href={category.href}>
                    {category.label} ({category.count})
                  </a>
                </li>
              ))}
            </ol>
          </div>
        ) : (
          <p class="content-toc-empty">No content yet.</p>
        )
      }

  <Fragment slot="toc">
    {
      categories.length > 0 ? (
        <ol class="content-toc-list">
          {categories.map((category) => (
            <li class="content-toc-item content-toc-item--depth-2">
              <a class="content-toc-link content-toc-link--depth-2" href={category.href}>
                {category.label}
              </a>
            </li>
          ))}
        </ol>
      ) : (
        <p class="content-toc-empty">No categories yet.</p>
      )
    }
  </Fragment>
</ContentShell>


