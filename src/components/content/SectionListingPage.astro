---
import CollectionPageShell from "../layout/CollectionPageShell.astro";
import "../../style/pages/content-page.css";
import "../../style/components/content/section-listing-page.css";

interface SectionCategoryEntry {
  archiveSlug: string;
  count: number;
  href: string;
  label: string;
}

interface Props {
  categories: SectionCategoryEntry[];
  pageLabel: string;
  viewAllHref: string;
  viewAllLabel: string;
}

const { categories, pageLabel, viewAllHref, viewAllLabel } = Astro.props as Props;

const toAnchorId = (value: string) => value.toLowerCase().trim().replace(/\s+/g, "-");
---

<CollectionPageShell
  tocClass="content-toc content-toc--listing"
  contentAriaLabel={`${pageLabel} listing content`}
  tocAriaLabel={`${pageLabel} categories`}
  tocEmptyText="No categories yet."
  tocItems={categories.map((category) => ({
    href: category.href,
    label: category.label,
    depth: 2 as const,
  }))}
>
      <header class="listing-header collection-page-header">
        <div class="listing-header-bar collection-page-header-bar">
          <h1 class="listing-header-title listing-header-title--compact collection-page-title collection-page-title--compact">{pageLabel}</h1>
          <a class="listing-view-all-link collection-page-view-all-link" href={viewAllHref}>
            <span>{viewAllLabel}</span>
            <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
      </header>

      {
        categories.length > 0 ? (
          <div class="listing-groups collection-page-groups">
            <ol class="content-toc-list" aria-label={`${pageLabel} categories`}>
              {categories.map((category) => (
                <li id={toAnchorId(category.label)} class="content-toc-item content-toc-item--depth-2">
                  <a class="content-toc-link content-toc-link--depth-2" href={category.href}>
                    {category.label} ({category.count})
                  </a>
                </li>
              ))}
            </ol>
          </div>
        ) : (
          <p class="content-toc-empty">No content yet.</p>
        )
      }
</CollectionPageShell>
