---
import ContentShell from "../layout/ContentShell.astro";
import "../../style/pages/content-page.css";

interface TocHeading {
  depth: 1 | 2 | 3;
  slug: string;
  text: string;
}

interface Props {
  section: string;
  title: string;
  description?: string;
  articleType: string;
  author: string;
  articleRoutePath: string;
  walineServerURL?: string;
  createdLabel: string;
  updatedLabel: string;
  articleWordCount: number;
  tocHeadings: TocHeading[];
  ArticleContent: any;
}

const {
  section,
  title,
  description = "",
  articleType,
  author,
  articleRoutePath,
  walineServerURL = "",
  createdLabel,
  updatedLabel,
  articleWordCount,
  tocHeadings,
  ArticleContent,
} = Astro.props as Props;
---

<ContentShell
  variant="article"
  contentClass="content-page content-page--article"
  contentAriaLabel={`${section} article content`}
  tocAriaLabel={`${section} table of contents`}
>
      <header class="article-content-header">
        <p class="article-content-section">{section.toUpperCase()}</p>
        <h1 class="article-content-title">{title}</h1>
        {
          description && <p class="article-content-description">{description}</p>
        }
        <div class="article-content-meta" aria-label="Article metadata">
          <p class="article-content-meta-item"><span>Type</span><strong>{articleType}</strong></p>
          <p class="article-content-meta-item"><span>Author</span><strong>{author}</strong></p>
          <p class="article-content-meta-item"><span>Created</span><strong>{createdLabel}</strong></p>
          <p class="article-content-meta-item"><span>Updated</span><strong>{updatedLabel}</strong></p>
          <p class="article-content-meta-item">
            <span>Views</span>
            <strong>
              <span
                class="waline-pageview-count"
                data-path={articleRoutePath}
                data-server-url={walineServerURL}
              >
                —
              </span>
            </strong>
          </p>
          <p class="article-content-meta-item"><span>Words</span><strong>{articleWordCount.toLocaleString("en-US")}</strong></p>
        </div>
      </header>

      <ArticleContent />


  <script is:inline type="module">
    const pageviewElement = document.querySelector(".waline-pageview-count[data-server-url]");
    const serverURL = pageviewElement?.getAttribute("data-server-url")?.trim();
    const path = pageviewElement?.getAttribute("data-path")?.trim();

    if (serverURL && path) {
      const { pageviewCount } = await import("https://unpkg.com/@waline/client@v3/dist/pageview.js");

      pageviewCount({
        serverURL,
        path,
      });
    }
  </script>

  <Fragment slot="toc">
    {
      tocHeadings.length > 0 ? (
        <ol class="content-toc-list">
          {tocHeadings.map((heading) => (
            <li
              class:list={[
                "content-toc-item",
                `content-toc-item--depth-${heading.depth}`,
              ]}
            >
              <a class={`content-toc-link content-toc-link--depth-${heading.depth}`} href={`#${heading.slug}`}>
                {heading.text}
              </a>
            </li>
          ))}
        </ol>
      ) : (
        <p class="content-toc-empty">No headings yet.</p>
      )
    }
  </Fragment>
</ContentShell>
