---
import DocumentPageShell from "../layout/DocumentPageShell.astro";
import "../../style/pages/content-page.css";

interface TocHeading {
  depth: 1 | 2 | 3;
  slug: string;
  text: string;
}

interface Props {
  section: string;
  title: string;
  description?: string;
  articleType: string;
  author: string;
  articleRoutePath: string;
  walineServerURL?: string;
  createdLabel: string;
  updatedLabel: string;
  articleWordCount: number;
  tocHeadings: TocHeading[];
  ArticleContent: any;
}

const {
  section,
  title,
  description = "",
  articleType,
  author,
  articleRoutePath,
  walineServerURL = "",
  createdLabel,
  updatedLabel,
  articleWordCount,
  tocHeadings,
  ArticleContent,
} = Astro.props as Props;
---

<DocumentPageShell
  variant="article"
  contentClass="content-page content-page--article"
  contentAriaLabel={`${section} article content`}
  tocAriaLabel={`${section} table of contents`}
  tocItems={tocHeadings.map((heading) => ({
    href: `#${heading.slug}`,
    label: heading.text,
    depth: heading.depth,
  }))}
>
      <header class="article-content-header">
        <p class="article-content-section">{section.toUpperCase()}</p>
        <h1 class="article-content-title">{title}</h1>
        {
          description && <p class="article-content-description">{description}</p>
        }
        <div class="article-content-meta" aria-label="Article metadata">
          <p class="article-content-meta-item"><span>Author</span><strong>{author}</strong></p>
          <p class="article-content-meta-item"><span>Type</span><strong>{articleType}</strong></p>
          <p class="article-content-meta-item"><span>Created</span><strong>{createdLabel}</strong></p>
          <p class="article-content-meta-item"><span>Updated</span><strong>{updatedLabel}</strong></p>
          <p class="article-content-meta-item">
            <span>Views</span>
            <strong>
              <span
                class="waline-pageview-count"
                data-path={articleRoutePath}
                data-server-url={walineServerURL}
              >
                —
              </span>
            </strong>
          </p>
          <p class="article-content-meta-item"><span>Words</span><strong>{articleWordCount.toLocaleString("en-US")}</strong></p>
        </div>
      </header>

      <ArticleContent />

      <footer class="article-license" aria-label="Article license notice">
        <p class="article-license-text">
          商业转载请联系站长获得授权，非商业转载请注明本文出处及文章链接，您可以自由地在任何媒体以任何形式复制和分发作品，也可以修改和创作，但是分发衍生作品时必须采用相同的许可协议。本文采用
          <a
            class="article-license-link"
            href="https://creativecommons.org/licenses/by-nc-sa/4.0/"
            target="_blank"
            rel="noreferrer"
          >
            CC BY-NC-SA 4.0 - 非商业性使用 - 相同方式共享 4.0 国际
          </a>
          进行许可。
        </p>
      </footer>

      <section
        class="article-comments"
        aria-label="Comments"
        data-article-waline
        data-waline-server-url={walineServerURL}
        data-waline-path={articleRoutePath}
      >
        <header class="article-comments-header">
          <h2 class="article-comments-title">Comments</h2>
          <p class="article-comments-description">Discuss this article here.</p>
        </header>
        {
          walineServerURL ? (
            <div class="article-comments-thread" data-waline-thread></div>
          ) : (
            <p class="article-comments-empty">
              Comments are unavailable until <code>PUBLIC_WALINE_SERVER_URL</code> is configured.
            </p>
          )
        }
      </section>


  <script>
    import { init } from "@waline/client";

    const walineRoots = document.querySelectorAll("[data-article-waline]");

    walineRoots.forEach((walineRoot) => {
      const walineThread = walineRoot.querySelector("[data-waline-thread]");
      const serverURL = walineRoot.getAttribute("data-waline-server-url")?.trim();
      const path = walineRoot.getAttribute("data-waline-path")?.trim();
      const lang = document.documentElement.lang === "zh-CN" ? "zh-CN" : "en";

      if (!serverURL) {
        console.warn("[Waline] PUBLIC_WALINE_SERVER_URL is not configured.");
        return;
      }

      if (!(walineThread instanceof HTMLElement) || !path) {
        return;
      }

      init({
        el: walineThread,
        serverURL,
        path,
        lang,
        pageview: true,
      });
    });
  </script>
</DocumentPageShell>
