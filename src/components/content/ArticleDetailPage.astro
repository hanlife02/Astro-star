---
import DocumentPageShell from "../layout/DocumentPageShell.astro";
import WalineComments from "./WalineComments.astro";

interface TocHeading {
  depth: 1 | 2 | 3;
  slug: string;
  text: string;
}

interface AdjacentArticle {
  href: string;
  title: string;
}

interface Props {
  section: string;
  title: string;
  description?: string;
  articleType: string;
  author: string;
  articleRoutePath: string;
  walineServerURL?: string;
  createdLabel: string;
  updatedLabel: string;
  createdAtIso?: string;
  updatedAtIso?: string;
  articleWordCount: number;
  nextArticle?: AdjacentArticle | null;
  previousArticle?: AdjacentArticle | null;
  tocHeadings: TocHeading[];
  ArticleContent: any;
  canonicalUrl?: string;
  imageUrl?: string;
  siteName?: string;
  includeKatexStyles?: boolean;
}

const {
  section,
  title,
  description = "",
  articleType,
  author,
  articleRoutePath,
  walineServerURL = "",
  createdLabel,
  updatedLabel,
  createdAtIso = "",
  updatedAtIso = "",
  articleWordCount,
  nextArticle = null,
  previousArticle = null,
  tocHeadings,
  ArticleContent,
  canonicalUrl = "",
  imageUrl = "",
  siteName = "",
  includeKatexStyles = false,
} = Astro.props as Props;

const pageTitle = siteName ? `${title} - ${siteName}` : title;
const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description: description || undefined,
  author: {
    "@type": "Person",
    name: author,
  },
  publisher: {
    "@type": "Person",
    name: author,
  },
  datePublished: createdAtIso || undefined,
  dateModified: updatedAtIso || createdAtIso || undefined,
  mainEntityOfPage: canonicalUrl
    ? {
        "@type": "WebPage",
        "@id": canonicalUrl,
      }
    : undefined,
  url: canonicalUrl || undefined,
  image: imageUrl ? [imageUrl] : undefined,
  isPartOf: siteName
    ? {
        "@type": "WebSite",
        name: siteName,
      }
    : undefined,
};
const articleJsonLdText = JSON.stringify(articleJsonLd).replace(
  /</g,
  "\\u003c",
);
---

<DocumentPageShell
  variant="article"
  title={pageTitle}
  description={description || undefined}
  canonicalUrl={canonicalUrl || undefined}
  imageUrl={imageUrl || undefined}
  ogTitle={title}
  ogType="article"
  twitterCard={imageUrl ? "summary_large_image" : "summary"}
  includeKatexStyles={includeKatexStyles}
  contentClass="content-page content-page--article"
  contentAriaLabel={`${section} article content`}
  tocAriaLabel={`${section} table of contents`}
  tocItems={tocHeadings.map((heading) => ({
    href: `#${heading.slug}`,
    label: heading.text,
    depth: heading.depth,
  }))}
>
  <Fragment slot="head">
    <meta name="article:author" content={author} />
    {
      createdAtIso && (
        <meta property="article:published_time" content={createdAtIso} />
      )
    }
    {
      updatedAtIso && (
        <meta property="article:modified_time" content={updatedAtIso} />
      )
    }
    <script is:inline type="application/ld+json" set:html={articleJsonLdText} />
  </Fragment>
  <header class="article-content-header">
    <h1 class="article-content-title">{title}</h1>
    {description && <p class="article-content-description">{description}</p>}
    <div class="article-content-meta" aria-label="Article metadata">
      <p class="article-content-meta-line">
        <span class="article-content-meta-label">Type</span>{" "}
        <span class="article-content-meta-value">{articleType}</span>
      </p>
      <p class="article-content-meta-line">
        <span class="article-content-meta-label">Created</span>{" "}
        <span class="article-content-meta-value">{createdLabel}</span>
        <span class="article-content-meta-separator">/</span>
        <span class="article-content-meta-label">Updated</span>{" "}
        <span class="article-content-meta-value">{updatedLabel}</span>
      </p>
      <p class="article-content-meta-line">
        <span class="article-content-meta-label">Views</span>{" "}
        <span
          class="article-content-meta-value waline-pageview-count"
          data-path={articleRoutePath}
          data-server-url={walineServerURL}
        >
          —
        </span>
        <span class="article-content-meta-separator">/</span>
        <span class="article-content-meta-label">Comments</span>{" "}
        <span
          class="article-content-meta-value waline-comment-count"
          data-path={articleRoutePath}
          data-server-url={walineServerURL}
        >
          —
        </span>
        <span class="article-content-meta-separator">/</span>
        <span class="article-content-meta-label">Words</span>{" "}
        <span class="article-content-meta-value"
          >{articleWordCount.toLocaleString("en-US")}</span
        >
      </p>
    </div>
  </header>

  <ArticleContent />

  {
    (previousArticle || nextArticle) && (
      <nav class="article-neighbors" aria-label="Adjacent articles">
        {previousArticle && (
          <a
            class="article-neighbor article-neighbor--previous"
            href={previousArticle.href}
          >
            <span class="article-neighbor-label">Previous</span>
            <span class="article-neighbor-title">{previousArticle.title}</span>
          </a>
        )}
        {nextArticle && (
          <a
            class="article-neighbor article-neighbor--next"
            href={nextArticle.href}
          >
            <span class="article-neighbor-label">Next</span>
            <span class="article-neighbor-title">{nextArticle.title}</span>
          </a>
        )}
      </nav>
    )
  }

  <footer class="article-license" aria-label="Article license notice">
    <p class="article-license-text">
      商业转载请联系站长获得授权，非商业转载请注明本文出处及文章链接，您可以自由地在任何媒体以任何形式复制和分发作品，也可以修改和创作，但是分发衍生作品时必须采用相同的许可协议。本文采用
      <a
        class="article-license-link"
        href="https://creativecommons.org/licenses/by-nc-sa/4.0/"
        target="_blank"
        rel="noreferrer"
      >
        CC BY-NC-SA 4.0 - 非商业性使用 - 相同方式共享 4.0 国际
      </a>
      进行许可。
    </p>
  </footer>

  <WalineComments
    articleRoutePath={articleRoutePath}
    walineServerURL={walineServerURL}
  />
</DocumentPageShell>
