---
interface Props {
  title: string;
  href: string;
  createdLabel: string;
  description?: string;
}

const { title, href, createdLabel, description = "" } = Astro.props;
---

<article class="listing-card collection-page-card">
  <a class="listing-card-link collection-page-card-link" href={href}>
    <div class="listing-card-head collection-page-card-head">
      <h3 class="listing-card-title collection-page-card-title">{title}</h3>
      <span class="listing-card-arrow collection-page-card-arrow" aria-hidden="true">→</span>
    </div>
    <p class="listing-card-meta collection-page-card-meta">{createdLabel}</p>
    {description && <p class="listing-card-description collection-page-card-description">{description}</p>}
  </a>
</article>
