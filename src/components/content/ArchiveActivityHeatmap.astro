---
import "../../style/components/content/archive-activity-heatmap.css";

interface ActivityEntry {
  date: string;
}

interface Props {
  entries: ActivityEntry[];
  label: string;
}

interface ActivityBucket {
  count: number;
  key: string;
  level: number;
  title: string;
  x: number;
}

interface ActivityMonth {
  count: number;
  index: number;
  key: string;
  label: string;
  level: number;
  title: string;
  x: number;
}

const { entries, label } = Astro.props as Props;

const monthFormatter = new Intl.DateTimeFormat("en-US", {
  month: "long",
  year: "numeric",
  timeZone: "UTC",
});

function getDateKey(value: string) {
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return "";
  return date.toISOString().slice(0, 10);
}

function getUtcDate(dateKey: string) {
  return new Date(`${dateKey}T00:00:00.000Z`);
}

function addMonths(date: Date, count: number) {
  const nextDate = new Date(date.getTime());
  nextDate.setUTCMonth(nextDate.getUTCMonth() + count);
  return nextDate;
}

function getLevel(count: number, maxCount: number) {
  if (count <= 0) return 0;
  if (maxCount <= 4) return Math.min(4, count);
  return Math.max(1, Math.ceil((count / maxCount) * 4));
}

function getMonthIndex(date: Date, rangeStart: Date) {
  return (
    (date.getUTCFullYear() - rangeStart.getUTCFullYear()) * 12 +
    date.getUTCMonth() -
    rangeStart.getUTCMonth()
  );
}

function getWeekIndex(date: Date) {
  return Math.min(3, Math.floor((date.getUTCDate() - 1) / 7));
}

function getMonthPosition(index: number) {
  return 4.5 + (index / 12) * 91;
}

function getBucketPosition(monthIndex: number, weekIndex: number) {
  return 4.5 + ((monthIndex + (weekIndex + 1) / 5) / 12) * 91;
}

const countsByDate = entries.reduce<Map<string, number>>((counts, entry) => {
  const dateKey = getDateKey(entry.date);
  if (!dateKey) return counts;

  counts.set(dateKey, (counts.get(dateKey) ?? 0) + 1);
  return counts;
}, new Map());

const activeDateKeys = Array.from(countsByDate.keys()).sort();
const lastDate = activeDateKeys.at(-1)
  ? getUtcDate(activeDateKeys.at(-1) as string)
  : null;
const rangeEnd = lastDate
  ? new Date(Date.UTC(lastDate.getUTCFullYear(), lastDate.getUTCMonth() + 1, 0))
  : null;
const rangeStart = rangeEnd
  ? addMonths(
      new Date(Date.UTC(rangeEnd.getUTCFullYear(), rangeEnd.getUTCMonth(), 1)),
      -11,
    )
  : null;
const buckets: ActivityBucket[] = [];
const months: ActivityMonth[] = [];

if (rangeStart && rangeEnd) {
  const countsByBucket = new Map<string, number>();
  const countsByMonth = new Map<number, number>();

  for (const key of activeDateKeys) {
    const count = countsByDate.get(key) ?? 0;
    const currentDate = getUtcDate(key);
    const monthIndex = getMonthIndex(currentDate, rangeStart);

    if (monthIndex < 0 || monthIndex > 11) continue;

    const weekIndex = getWeekIndex(currentDate);
    const bucketKey = `${monthIndex}-${weekIndex}`;
    countsByBucket.set(bucketKey, (countsByBucket.get(bucketKey) ?? 0) + count);
    countsByMonth.set(monthIndex, (countsByMonth.get(monthIndex) ?? 0) + count);
  }

  const maxCount = Math.max(...countsByBucket.values(), 1);
  const maxMonthCount = Math.max(...countsByMonth.values(), 1);
  let monthIndex = 0;

  for (
    let currentMonth = rangeStart;
    currentMonth.getTime() <= rangeEnd.getTime();
    currentMonth = addMonths(currentMonth, 1)
  ) {
    const count = countsByMonth.get(monthIndex) ?? 0;

    months.push({
      count,
      index: monthIndex,
      key: currentMonth.toISOString().slice(0, 7),
      label: `${currentMonth.getUTCFullYear()}.${currentMonth.getUTCMonth() + 1}`,
      level: getLevel(count, maxMonthCount),
      title: `${count} ${count === 1 ? "post" : "posts"} in ${monthFormatter.format(currentMonth)}`,
      x: getMonthPosition(monthIndex),
    });
    monthIndex += 1;
  }

  for (const [key, count] of countsByBucket.entries()) {
    const [monthIndexValue, weekIndexValue] = key
      .split("-")
      .map((value) => Number.parseInt(value, 10));
    const currentMonth = addMonths(rangeStart, monthIndexValue);
    const title = `${count} ${count === 1 ? "post" : "posts"} in week ${
      weekIndexValue + 1
    } of ${monthFormatter.format(currentMonth)}`;

    buckets.push({
      count,
      key,
      level: getLevel(count, maxCount),
      title,
      x: getBucketPosition(monthIndexValue, weekIndexValue),
    });
  }
}
---

{
  buckets.length > 0 && (
    <section
      class="archive-activity-heatmap"
      aria-label={`${label} activity timeline heatmap`}
    >
      <div class="archive-activity-timeline-scroll">
        <div class="archive-activity-timeline">
          <div class="archive-activity-timeline-leading" aria-hidden="true" />
          <div class="archive-activity-timeline-line" aria-hidden="true" />

          {buckets.map((bucket) => (
            <span
              class="archive-activity-timeline-bar"
              data-level={bucket.level}
              style={`--archive-activity-x: ${bucket.x.toFixed(3)}%;`}
              title={bucket.title}
              aria-label={bucket.title}
            />
          ))}

          {months.map((month) => (
            <div
              class="archive-activity-timeline-month"
              data-month-index={month.index}
              style={`--archive-activity-x: ${month.x.toFixed(3)}%;`}
            >
              {month.count > 0 && (
                <span
                  class="archive-activity-timeline-month-bar"
                  data-level={month.level}
                  title={month.title}
                  aria-label={month.title}
                />
              )}
              <span class="archive-activity-timeline-dot" aria-hidden="true" />
              <span class="archive-activity-timeline-label">{month.label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>
  )
}
