---
import "../../style/components/background/home-background.css";

interface Props {
  revealAt?: string;
  mode?: "light" | "dark";
}

const { revealAt = "12% 12%", mode } = Astro.props satisfies Props;
const backgroundMode = mode === "dark" ? "dark" : undefined;
---

<div
  class="snow-bg"
  data-mode={backgroundMode}
  aria-hidden="true"
  style={`--snow-reveal-at:${revealAt};`}
></div>
