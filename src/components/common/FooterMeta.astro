---
import { site } from "../../config/site";
import "../../style/components/home/footer-info.css";

interface Props {
  repoHref?: string;
  separator?: string;
}

const { repoHref = "https://github.com/hanlife02/Astro-star", separator = "|" } = Astro.props as Props;
const currentYear = new Date().getFullYear();
const copyrightYears = `${site.site.startYear}-${currentYear}`;
---

<div class="footer-meta" aria-label="Site footer information">
  <p class="footer-meta-line">
    <a class="footer-meta-link footer-meta-link--copyright" href={repoHref} target="_blank" rel="noreferrer">
      @{copyrightYears} Astro-star
    </a>
    <span class="footer-meta-separator footer-meta-separator--primary" aria-hidden="true">{separator}</span>
    <span class="footer-meta-group">
      <a class="footer-meta-link" href={site.site.beian.icp.href} target="_blank" rel="noreferrer">
        {site.site.beian.icp.text}
      </a>
      <span class="footer-meta-separator" aria-hidden="true">{separator}</span>
      <a class="footer-meta-link" href={site.site.beian.moe.href} target="_blank" rel="noreferrer">
        {site.site.beian.moe.text}
      </a>
    </span>
  </p>
</div>
