---
import { linkApplyOwner } from "../../config/links";

const ownerInfoText = [
  `Name: ${linkApplyOwner.name}`,
  `Desc: ${linkApplyOwner.description}`,
  `Link: ${linkApplyOwner.href}`,
  `Avatar: ${linkApplyOwner.avatarSrc}`,
].join("\n");
---

<pre class="link-owner-info-code"><code>{ownerInfoText}</code></pre>
