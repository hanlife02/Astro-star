---
import { site } from "../../config/site";
import "../../style/components/home/signature.css";

const profile = site.profile as {
  signatureSvg?: string;
};
const signatureSvg = profile.signatureSvg ?? "";
const signatureAssetSrc = "/signature.svg";

const normalizeSvgMarkup = (input: string) => {
  let value = input.trim();

  if ((value.startsWith('"') && value.endsWith('"')) || (value.startsWith("'") && value.endsWith("'"))) {
    value = value.slice(1, -1);
  } else {
    value = value.replace(/^['"]/, "").replace(/['"]$/, "");
  }

  return value.replace(/\\"/g, '"').replace(/\\'/g, "'");
};

const svgMarkup = normalizeSvgMarkup(signatureSvg);
const isValidSvg = svgMarkup.startsWith("<svg") && svgMarkup.includes("</svg>");
const hasSignatureAsset = isValidSvg;
const signatureMaskStyle = hasSignatureAsset
  ? `--signature-mask: url("${signatureAssetSrc}");`
  : undefined;
---

{
  (hasSignatureAsset || isValidSvg) && (
    <a class="signature-wrap" href="/" aria-label="Back to home">
      <span
        class="signature-mark"
        aria-hidden="true"
        data-signature-src={hasSignatureAsset ? "true" : undefined}
        data-signature-asset={hasSignatureAsset ? signatureAssetSrc : undefined}
        style={signatureMaskStyle}
      />
    </a>
  )
}
