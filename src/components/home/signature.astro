---
import { site } from "../../config/site";
import "../../style/components/home/signature.css";

const signatureSvg = site.profile.signatureSvg;

const normalizeSvgMarkup = (input: string) => {
  let value = input.trim();

  if ((value.startsWith('"') && value.endsWith('"')) || (value.startsWith("'") && value.endsWith("'"))) {
    value = value.slice(1, -1);
  } else {
    value = value.replace(/^['"]/, "").replace(/['"]$/, "");
  }

  return value.replace(/\\"/g, '"').replace(/\\'/g, "'");
};

const appendClassAttribute = (markup: string, tagName: string, className: string) => markup.replace(
  new RegExp(`<${tagName}\\b([^>]*)>`, "i"),
  (match, rawAttrs: string) => {
    if (/\bclass\s*=\s*(["']).*?\1/i.test(rawAttrs)) {
      return match.replace(/\bclass\s*=\s*(["'])(.*?)\1/i, (_classMatch, quote: string, value: string) => `class=${quote}${value} ${className}${quote}`);
    }

    return `<${tagName}${rawAttrs} class="${className}">`;
  },
);

const svgMarkup = normalizeSvgMarkup(signatureSvg);
const isValidSvg = svgMarkup.startsWith("<svg") && svgMarkup.includes("</svg>");
const signatureMarkup = isValidSvg ? appendClassAttribute(svgMarkup, "svg", "signature-svg") : "";
---

{
  isValidSvg && (
    <a class="signature-wrap" href="/" aria-label="Back to home">
      <span class="signature-mark" aria-hidden="true">
        <Fragment set:html={signatureMarkup} />
      </span>
    </a>
  )
}
