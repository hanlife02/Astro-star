---
import HomeLayout from "../../layouts/HomeLayout.astro";
import CodeTime from "./CodeTime.astro";
import GitHeatmap from "./githeatmap.astro";
import Signature from "./signature.astro";
import FooterMeta from "../common/FooterMeta.astro";
import Icon from "../ui/Icon.astro";
import BilibiliIcon from "../ui/icons/BilibiliIcon.astro";
import NetEaseMusicIcon from "../ui/icons/NetEaseMusicIcon.astro";
import "../../style/components/home/profile.css";
import "../../style/components/home/latest-articles.css";
import "../../style/components/home/home-page-content.css";
import "../../style/pages/home-page-entrance.css";

interface ProfileData {
  avatarSrc: string;
  bio: string;
  intro: string;
}

interface ProfileLinkItem {
  key: string;
  label: string;
  href: string;
  icon?: any;
  external: boolean;
}

interface LatestArticleItem {
  title: string;
  href: string;
  pubDateIso: string;
  createdAtIso: string;
  updatedAtIso: string;
  displayDate: string;
  year: string;
  timestamp: number;
}

interface LatestTimelineGroup {
  year: string;
  articles: LatestArticleItem[];
}

interface Props {
  profile: ProfileData;
  ownerName: string;
  profileLinks: ProfileLinkItem[];
  latestBlogTimelineGroups: LatestTimelineGroup[];
  latestNoteTimelineGroups: LatestTimelineGroup[];
  latestAnimationOrderMap: Map<string, number>;
}

const {
  profile,
  ownerName,
  profileLinks,
  latestBlogTimelineGroups,
  latestNoteTimelineGroups,
  latestAnimationOrderMap,
} = Astro.props as Props;
---

<HomeLayout>
  <Signature slot="signature" />
  <section slot="profile" class="profile-card home-profile-sequence" aria-label="Profile section">
    <img
      class="profile-avatar home-enter-item"
      src={profile.avatarSrc}
      alt={ownerName}
      width="1080"
      height="1080"
      loading="eager"
      decoding="async"
    />
    <h2 class="profile-name home-enter-item">{ownerName}</h2>
    {
      profileLinks.length > 0 && (
        <nav class="profile-links" aria-label="Profile quick links">
          {
            profileLinks.map((item) => (
              <a
                class="profile-link home-enter-item"
                href={item.href}
                target={item.external ? "_blank" : undefined}
                rel={item.external ? "noreferrer" : undefined}
                aria-label={item.label}
              >
                {item.key === "bilibili" ? <BilibiliIcon /> : null}
                {item.key === "cloud-music" ? <NetEaseMusicIcon /> : null}
                {item.key !== "bilibili" && item.key !== "cloud-music" ? <Icon svg={item.icon} /> : null}
              </a>
            ))
          }
        </nav>
      )
    }
    <p class="profile-one-word home-enter-item">{profile.bio}</p>
    <p class="profile-bio home-enter-item">{profile.intro}</p>
    <div class="home-profile-metrics">
      <div class="home-enter-item home-profile-metric">
        <CodeTime />
      </div>
      <div class="home-enter-item home-profile-metric">
        <GitHeatmap />
      </div>
    </div>
  </section>
  <section slot="latest" class="latest-articles home-latest-sequence" aria-label="Latest content section" data-latest-enhanced="true">
    {
      [
        { key: "blogs", title: "Latest Blogs", groups: latestBlogTimelineGroups },
        { key: "notes", title: "Latest Notes", groups: latestNoteTimelineGroups },
      ].map((block) => (
        <section
          class="latest-articles-panel"
          aria-label={block.title}
          data-latest-key={block.key}
        >
          <h2 class="latest-articles-title">{block.title}</h2>
          {
            block.groups.length > 0 ? (
              <div class="latest-articles-groups" aria-label={`${block.title} timeline`}>
                {
                  block.groups.map((group) => (
                    <section class="latest-articles-group" aria-label={`${group.year} articles`}>
                      <h3 class="latest-articles-year-label">{group.year}</h3>
                      <ol class="latest-articles-list" aria-label={`${group.year} timeline`}>
                        {
                          group.articles.map((article, index) => (
                            <li
                              class:list={[
                                "latest-articles-item",
                                index === 0 && "latest-articles-item--year-start",
                                index === group.articles.length - 1 && "latest-articles-item--year-end",
                              ]}
                            >
                              <div
                                class="latest-articles-item-content"
                                style={`--latest-enter-order: ${latestAnimationOrderMap.get(article.href) ?? 0};`}
                              >
                                <time class="latest-articles-time" datetime={article.pubDateIso}>
                                  {article.displayDate}
                                </time>
                                <a class="latest-articles-link" href={article.href}>
                                  {article.title}
                                </a>
                              </div>
                            </li>
                          ))
                        }
                      </ol>
                    </section>
                  ))
                }
              </div>
            ) : (
              <p class="latest-articles-empty">No {block.key} published yet.</p>
            )
          }
        </section>
      ))
    }

    <script is:inline>
      (() => {
        const runHomeEntrance = () => {
          const profileRoot = document.querySelector(".home-profile-sequence");
          const latestRoot = document.querySelector(".home-latest-sequence");
          if (!(profileRoot instanceof HTMLElement) || !(latestRoot instanceof HTMLElement)) return;

          profileRoot.dataset.homeEntranceEnabled = "true";
          latestRoot.dataset.homeEntranceEnabled = "true";

          const runToken = `${Date.now()}`;
          profileRoot.dataset.homeEntranceRun = runToken;

          const profileItems = Array.from(profileRoot.querySelectorAll(".home-enter-item, .home-profile-metric"));
          profileItems.forEach((element, index) => {
            if (element instanceof HTMLElement) {
              element.style.setProperty("--home-enter-order", `${index}`);
            }
          });

          const reset = () => {
            profileItems.forEach((element) => {
              if (element instanceof HTMLElement) {
                element.classList.remove("is-visible");
              }
            });

            latestRoot.classList.remove("latest-articles--frame-visible", "latest-articles--entered");
          };

          reset();
          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              if (profileRoot.dataset.homeEntranceRun !== runToken) return;

              profileItems.forEach((element) => {
                if (element instanceof HTMLElement) {
                  element.classList.add("is-visible");
                }
              });

              latestRoot.classList.add("latest-articles--frame-visible", "latest-articles--entered");
            });
          });
        };

        if (!window.__homeEntrancePageLoadBound) {
          document.addEventListener("astro:page-load", () => {
            if (typeof window.__runHomeEntrance === "function") {
              window.__runHomeEntrance();
            }
          });
          window.__homeEntrancePageLoadBound = true;
        }

        window.__runHomeEntrance = runHomeEntrance;
        runHomeEntrance();
      })();
    </script>
  </section>
  <FooterMeta slot="footer-info" />
</HomeLayout>
